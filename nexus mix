            if (!t) return;
            t.textContent = msg;
            t.classList.add('show');
            clearTimeout(this.toastTimer);
            this.toastTimer = setTimeout(() => t.classList.remove('show'), 2400);
        },

        validateChain(showToast = false) {
            const valid = new Set(['A','B','C','D','E','F','G','H']);
            const chain = Array.isArray(songChain) ? songChain : [];
            const invalid = chain.filter(x => !valid.has(String(x)));
            const emptyPatterns = [...new Set(chain)].filter(letter => {
                const p = Patterns?.[letter];
                if (!p) return true;
                const drums = p.drums || p;
                const melody = p.melody || [];
                const drumHits = tracks.reduce((sum,t)=> sum + ((drums?.[t] || []).filter(Boolean).length), 0);
                const melodyHits = Array.isArray(melody) ? melody.reduce((sum,step)=> sum + (Array.isArray(step) ? step.length : (step ? 1 : 0)), 0) : 0;
                return drumHits + melodyHits === 0;
            });
            let status = 'Ready';
            let tone = 'ok';
            if (!chain.length) { status = 'Empty chain'; tone = 'warn'; }
            else if (invalid.length) { status = `${invalid.length} invalid item${invalid.length === 1 ? '' : 's'}`; tone = 'danger'; }
            else if (emptyPatterns.length) { status = `Empty pattern: ${emptyPatterns.join(', ')}`; tone = 'warn'; }
            else status = `${chain.length} step${chain.length === 1 ? '' : 's'} locked`;
            if (showToast) this.toast(`Chain Health: ${status}`);
            return { status, tone, invalid, emptyPatterns, length: chain.length };
        },

        refreshCommandCenter() {
            const chain = this.validateChain(false);
            const chainCard = document.getElementById('v44ChainCard');
            const chainText = document.getElementById('v44ChainText');
            if (chainText) chainText.textContent = chain.status;
            if (chainCard) {
