    const pr = getTrackPitchRatio('tom');
    const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain(); osc.frequency.setValueAtTime(168 * pr, time); osc.frequency.exponentialRampToValueAtTime(52 * pr, time + 0.38);
    gain.gain.setValueAtTime(0.95, time); gain.gain.exponentialRampToValueAtTime(0.001, time + 0.42); osc.connect(gain); gain.connect(trackGain); osc.start(time); osc.stop(time + 0.45); visTrigger('btnTom', time);
}

function playCrash(time = audioCtx.currentTime) {
    if (!isAudioInit) initAudio(); const trackGain = makeDrumTrackGain('crash');
    const pr = getTrackPitchRatio('crash');
    const noise = audioCtx.createBufferSource(); noise.buffer = Engine.noiseBuffer; noise.playbackRate.value = pr; const filt = audioCtx.createBiquadFilter(); filt.type = 'highpass'; filt.frequency.value = 2800 * pr;
    const gain = audioCtx.createGain(); gain.gain.setValueAtTime(0.75, time); gain.gain.exponentialRampToValueAtTime(0.001, time + 1.6);
    noise.connect(filt); filt.connect(gain); gain.connect(trackGain); noise.start(time); noise.stop(time + 1.7); visTrigger('btnCrash', time);
