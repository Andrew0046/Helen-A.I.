    function makeBitcrushCurve(amount){
        const n=2048, curve=new Float32Array(n);
        if (!amount || amount < .01) { for(let i=0;i<n;i++) curve[i]=i*2/n-1; return curve; }
        const bits = Math.max(3, Math.round(16 - amount*12));
        const steps = Math.pow(2,bits);
        for(let i=0;i<n;i++){ const x=i*2/n-1; curve[i]=Math.round(x*steps)/steps; }
        return curve;
    }
    function makeVoiceDriveCurve(amount){
        const n=2048, curve=new Float32Array(n), k=1 + amount*38;
        for(let i=0;i<n;i++){ const x=i*2/n-1; curve[i]=Math.tanh(k*x)/Math.tanh(k); }
        return curve;
    }

