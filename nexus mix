            document.querySelectorAll(`.melody-step[data-step="${ev.step}"]`).forEach(el => el.classList.add('current-col'));
            const prev = ev.step === 0 ? 15 : ev.step - 1;
            tracks.forEach(t => { const el = document.getElementById(`seq-${t}-${prev}`); if (el) el.classList.remove('current-col'); });
            document.querySelectorAll(`.melody-step[data-step="${prev}"]`).forEach(el => el.classList.remove('current-col'));
