                const limiter = State?.engine?.limiter != null ? `${Math.round(State.engine.limiter * 100)}% limiter` : 'Limiter ready';
                sound.textContent = `${hq} • ${limiter} • track FX ready`;
            }
            const ex = document.getElementById('v44ExportText');
            if (ex) {
                const bars = songChain?.length || NexusV41?.arrangement?.length || 1;
                ex.textContent = `Project has ${bars} section${bars === 1 ? '' : 's'} ready to save/export.`;
            }
        }
    };

    window.NexusV44 = V44;
    const previousOnload44 = window.onload;
    window.onload = function(...args) {
        if (typeof previousOnload44 === 'function') previousOnload44.apply(this, args);
        V44.init();
    };
})();



/* =========================
   v4.4.1 STABILITY / OVERFLOW FIX
   - Prevents current-step UI scale overflow.
   - Stops song-chain pattern changes from rebuilding heavy grids while audio is running.
   - Replaces transport clock with a single guarded clock to prevent stacked timers.
   - Shortens per-hit FX node cleanup so dense chains do not overload the browser.
   ========================= */
(function installV441StabilityFix(){
    const css = document.createElement('style');
    css.id = 'v441StabilityStyles';
    css.textContent = `
        body.v44-polished .panel { overflow: clip; }
        .seq-with-controls, .performance-area, .track-fx-panel, .song-chain { contain: layout paint; }
        .seq-grid { min-width: 720px; }
        .track-controls { min-width: 720px; }
        .seq-step.current-col,
        .melody-step.current-col {
            transform: none !important;
            outline: 2px solid rgba(255,255,255,.95) !important;
            outline-offset: -2px;
            box-shadow: 0 0 10px rgba(255,255,255,.62) !important;
            z-index: 2;
        }
        .chain-list {
            max-height: 124px;
            overflow: auto;
            overscroll-behavior: contain;
            scroll-behavior: auto !important;
        }
        .chain-item.playing { box-shadow: 0 0 10px rgba(0,255,204,.45); }
        .fx-table { max-width: 100%; overflow-x: auto; overscroll-behavior-inline: contain; }
        .piano-container, .melody-roll { overscroll-behavior-inline: contain; }
    `;
    document.head.appendChild(css);

    let transportGeneration = 0;
    let renderRAF = null;
    let lastPatternRender = 0;
    let lastChainScroll = 0;
    const stableSong = { skipFirstBoundary: true, barCount: 0 };

    function safeStatus(msg) { try { if (typeof updateStatus === 'function') updateStatus(msg); } catch(e) {} }
    function stableNowMs() { return (window.performance && performance.now) ? performance.now() : Date.now(); }

    function updateTransportButton(playing) {
        const btn = document.getElementById('playSeqBtn');
        if (!btn) return;
        btn.innerText = playing ? '■ STOP' : '▶ PLAY';
        btn.style.background = playing ? 'var(--neon-secondary)' : 'var(--neon-primary)';
        btn.style.color = playing ? '#fff' : '#000';
    }

    function updateSongButton(playing) {
        const btn = document.getElementById('playSongBtn');
        if (!btn) return;
        btn.innerText = playing ? '■ STOP SONG' : '▶ PLAY SONG';
        btn.style.background = playing ? 'var(--neon-secondary)' : 'var(--neon-accent)';
        btn.style.color = playing ? '#fff' : '#000';
    }

    function setSongText(text) {
        const el = document.getElementById('songStatus');
        if (el) el.innerText = text;
    }

    function updatePatternButtons() {
        try {
            document.querySelectorAll('.pattern-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.pattern === currentPattern));
        } catch(e) {}
    }

    function updateChainVisual(forceScroll = false) {
        try {
            const items = document.querySelectorAll('#chainList .chain-item');
            items.forEach((item, idx) => item.classList.toggle('playing', isSongMode && idx === songIndex));
            const now = stableNowMs();
            const active = document.querySelector('#chainList .chain-item.playing');
            if (active && (forceScroll || now - lastChainScroll > 650)) {
                lastChainScroll = now;
                requestAnimationFrame(() => {
                    try { active.scrollIntoView({ block: 'nearest', inline: 'nearest' }); } catch(e) {}
                });
            }
        } catch(e) {}
    }

    function normalizePatternSnapshot(snapshot) {
        if (!snapshot) return { drums: makeEmptySeq(), melody: Array.from({length:16},()=>[]), melodyMeta: normalizeMelodyMeta?.() || [] };
        if (snapshot.drums) {
            return {
                drums: copySeqData(snapshot.drums),
                melody: typeof normalizeMelodyData === 'function' ? normalizeMelodyData(snapshot.melody) : (snapshot.melody || Array.from({length:16},()=>[])),
                melodyMeta: typeof normalizeMelodyMeta === 'function' ? normalizeMelodyMeta(snapshot.melodyMeta) : (snapshot.melodyMeta || [])
            };
        }
        return {
            drums: copySeqData(snapshot),
            melody: Array.from({ length: 16 }, () => []),
            melodyMeta: typeof normalizeMelodyMeta === 'function' ? normalizeMelodyMeta() : []
        };
    }

    function assignPatternData(letter, renderMode = 'defer') {
        if (!Patterns || !Patterns[letter]) return false;
        try { if (typeof saveCurrentPattern === 'function') saveCurrentPattern(); } catch(e) {}
        const data = normalizePatternSnapshot(Patterns[letter]);
        currentPattern = letter;
        seqData = data.drums;
        melodyData = data.melody;
        if (typeof melodyStepMeta !== 'undefined') melodyStepMeta = data.melodyMeta;
        updatePatternButtons();
        if (renderMode === 'now') {
            try { renderSeqGrid(); } catch(e) {}
            try { if (typeof renderMelodyGrid === 'function') renderMelodyGrid(); } catch(e) {}
            try { if (typeof updateMelodyStepInspector === 'function') updateMelodyStepInspector(); } catch(e) {}
            lastPatternRender = stableNowMs();
