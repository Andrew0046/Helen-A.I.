    };
    const addNoise = (f, level = .025) => {
        if (!Engine.noiseBuffer) return;
        const noise = audioCtx.createBufferSource(); noise.buffer = Engine.noiseBuffer;
        const nf = audioCtx.createBiquadFilter(); nf.type = 'bandpass'; nf.frequency.value = f * 1.65; nf.Q.value = 2.2;
        const ng = audioCtx.createGain(); ng.gain.value = level * velMod;
