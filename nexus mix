            if (Engine.master) pan.connect(Engine.master); else if (Engine.analyser) pan.connect(Engine.analyser);
            try { if (Engine.delay) { pan.connect(delaySend); delaySend.connect(Engine.delay); } } catch(e) {}
            try { if (Engine.rev) { pan.connect(revSend); revSend.connect(Engine.rev); } } catch(e) {}
