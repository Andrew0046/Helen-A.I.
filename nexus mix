    const humanize = parseFloat(document.getElementById('humanizeSlider').value); const jitter = (Math.random() - 0.5) * humanize * 0.012;
    soloActive = Object.values(trackSettings).some(t => t.solo);
    const shouldPlay = (track) => { const s = trackSettings[track]; if (s.muted) return false; if (soloActive && !s.solo) return false; if (Math.random() > s.prob) return false; return true; };
