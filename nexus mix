    function smartSliceVoice(){
        const ref = getSelectedVoiceSlot47();
        if (!ref?.slot?.buffer) { status47('Load or record a voice first'); return; }
        const src = ref.slot.buffer;
        const data = src.getChannelData(0);
        let peak = 0; for (let i=0; i<data.length; i += 128) peak = Math.max(peak, Math.abs(data[i]));
        const threshold = Math.max(0.015, peak * 0.18);
        let start = 0, end = data.length - 1;
        for (let i=0; i<data.length; i += 64) { if (Math.abs(data[i]) > threshold) { start = i; break; } }
        for (let i=data.length - 1; i>=0; i -= 64) { if (Math.abs(data[i]) > threshold) { end = i; break; } }
