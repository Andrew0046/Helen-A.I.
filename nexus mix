    },

    exportMidi() {
        saveCurrentPattern();
        const ppq = 480, stepTick = 120, bpm = parseInt(document.getElementById('bpmSlider')?.value || 128, 10), mpq = Math.round(60000000 / bpm);
        const events = [];
        const push = (tick, bytes) => events.push({tick, bytes});
        push(0, [0xff,0x51,0x03,(mpq>>16)&255,(mpq>>8)&255,mpq&255]);
