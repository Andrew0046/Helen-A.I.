    const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain(); const filter = audioCtx.createBiquadFilter(); const trackGain = makeDrumTrackGain('kick');
    filter.type = 'lowpass'; filter.frequency.value = currentDrumKit === 'lofi' ? 130 : 190;
    osc.connect(filter); filter.connect(gain); gain.connect(trackGain);
    const pr = getTrackPitchRatio('kick');
