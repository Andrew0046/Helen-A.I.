function scheduleNextStep() {
    const bpm = parseInt(document.getElementById('bpmSlider').value); const swing = State.synth.swing; const stepDuration = (60.0 / bpm) * 0.25;
    let swingOffset = 0; if (State.sequencer.currentStep % 2 === 1) swingOffset = stepDuration * swing;
    State.sequencer.nextNoteTime += stepDuration + swingOffset; State.sequencer.currentStep = (State.sequencer.currentStep + 1) % 16;
}

function scheduleAudioEvents(step, time) {
    uiDrawQueue.push({ step, time });
    if (State.project?.metronome) playMetronome(time, step === 0);
    const humanize = parseFloat(document.getElementById('humanizeSlider').value); const jitter = (Math.random() - 0.5) * humanize * 0.012;
    soloActive = Object.values(trackSettings).some(t => t.solo);
    
    const shouldPlay = (track) => { const s = trackSettings[track]; if (s.muted) return false; if (soloActive && !s.solo) return false; if (Math.random() > s.prob) return false; return true; };
    
    if (seqData.kick[step] && shouldPlay('kick')) playKick(time + jitter);
    if (seqData.snare[step] && shouldPlay('snare')) playSnare(time + jitter);
    if (seqData.clap[step] && shouldPlay('clap')) playClap(time + jitter);
    if (seqData.rim[step] && shouldPlay('rim')) playRim(time + jitter);
    if (seqData.hat[step] && shouldPlay('hat')) playHiHat(time + jitter);
    if (seqData.openhat[step] && shouldPlay('openhat')) playOpenHat(time + jitter);
    if (seqData.tom[step] && shouldPlay('tom')) playTom(time + jitter);
    if (seqData.perc[step] && shouldPlay('perc')) playPerc(time + jitter);
    if (seqData.ride[step] && shouldPlay('ride')) playRide(time + jitter);
    if (seqData.crash[step] && shouldPlay('crash')) playCrash(time + jitter);
    if (seqData.samp[step] && shouldPlay('samp')) playSample(time + jitter);

    const melodyNotes = normalizeMelodyStep(melodyData[step]);
    if (melodyNotes.length) {
        const bpm = parseInt(document.getElementById('bpmSlider').value);
        const stepDuration = (60.0 / bpm) * 0.25;
        State.melody.gateMs = Math.max(55, Math.min(950, stepDuration * State.melody.gate * 1000));
        melodyNotes.forEach((midi, noteIndex) => {
            playSynthNote(midiToFreq(midi), null, time + jitter + noteIndex * 0.003, true, Math.max(78, State.melody.velocity - noteIndex * 6));
        });
    }

    if (document.getElementById('arpActive').checked && document.getElementById('arpMode').value !== 'off' && State.arp.notes.length > 0) {
        let nextIndex = State.arp.index;
        const mode = document.getElementById('arpMode').value;
        if (mode === 'up') nextIndex = (State.arp.index + 1) % State.arp.notes.length;
        else if (mode === 'down') nextIndex = (State.arp.index - 1 + State.arp.notes.length) % State.arp.notes.length;
        else if (mode === 'random') nextIndex = Math.floor(Math.random() * State.arp.notes.length);
        
        State.arp.index = nextIndex;
        const el = State.arp.notes[nextIndex];
        if (el && el.dataset.freq) { playSynthNote(parseFloat(el.dataset.freq), el, time, true); if (visualMode !== 'spectrum' && Math.random() < 0.7) triggerVisualEvent('synth', 0.45); }
    }
}

function masterClockLookahead() {
    if (!State.sequencer.isPlaying) {
        clearTimeout(timerID);
        timerID = null;
        return;
    }
    while (State.sequencer.isPlaying && State.sequencer.nextNoteTime < audioCtx.currentTime + 0.085) {
        scheduleAudioEvents(State.sequencer.currentStep, State.sequencer.nextNoteTime);
        if (!State.sequencer.isPlaying) break;
        scheduleNextStep();
    }
    if (State.sequencer.isPlaying) timerID = setTimeout(masterClockLookahead, 22);
}

function toggleSequencer() {
    const btn = document.getElementById('playSeqBtn'); State.sequencer.isPlaying = !State.sequencer.isPlaying;
    if (State.sequencer.isPlaying) {
        initAudio(); btn.innerText = '■ STOP'; btn.style.background = 'var(--neon-secondary)'; btn.style.color = '#fff';
        if (audioCtx.state === 'suspended') audioCtx.resume();
        State.sequencer.currentStep = 0; State.sequencer.nextNoteTime = audioCtx.currentTime + 0.04; masterClockLookahead(); updateStatus('SEQUENCER RUNNING');
    } else {
        btn.innerText = '▶ PLAY'; btn.style.background = 'var(--neon-primary)'; btn.style.color = '#000'; clearTimeout(timerID); if (isSongMode) stopSongPlayback();
        tracks.forEach(t => { for (let i = 0; i < 16; i++) { const el = document.getElementById(`seq-${t}-${i}`); if (el) el.classList.remove('current-col'); } });
        document.querySelectorAll('.melody-step.current-col').forEach(el => el.classList.remove('current-col'));
        updateStatus('SEQUENCER STOPPED');
    }
}

const Patterns = { A: null, B: null, C: null, D: null, E: null, F: null, G: null, H: null };
Object.keys(Patterns).forEach(k => Patterns[k] = capturePatternSnapshot());
let currentPattern = 'A'; let songChain = []; let isSongMode = false; let songIndex = 0; let songTimerID = null;

function saveCurrentPattern() { if (Patterns[currentPattern]) Patterns[currentPattern] = capturePatternSnapshot(); }
function loadPattern(letter) {
    if (!Patterns[letter]) return;
    saveCurrentPattern();
    currentPattern = letter;
    const snapshot = Patterns[letter];
    if (snapshot.drums) {
        seqData = copySeqData(snapshot.drums);
        melodyData = normalizeMelodyData(snapshot.melody);
    } else {
        // Backward compatibility for older pattern saves that stored only drum data.
        seqData = copySeqData(snapshot);
        melodyData = Array.from({ length: 16 }, () => []);
    }
    document.querySelectorAll('.pattern-btn').forEach(btn => { btn.classList.remove('active'); if (btn.dataset.pattern === letter) btn.classList.add('active'); });
    renderSeqGrid(); renderMelodyGrid(); updateStatus(`PATTERN ${letter} LOADED`);
}

function renderChainList() {
    const container = document.getElementById('chainList'); container.innerHTML = '';
    if (songChain.length === 0) { const empty = document.createElement('span'); empty.style.color = '#444'; empty.style.fontSize = '11px'; empty.innerText = 'Empty — click "+ ADD CURRENT"'; container.appendChild(empty); return; }
    songChain.forEach((letter, index) => {
        const item = document.createElement('div'); item.className = 'chain-item'; item.innerHTML = `<span>${letter}</span><span class="remove" data-index="${index}">×</span>`;
        item.addEventListener('click', (e) => { if (e.target.classList.contains('remove')) return; loadPattern(letter); });
