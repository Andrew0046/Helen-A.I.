            for (let z = 8; z < 195; z += 17) {
                const scale = fov / (fov + z); const xProj = centerX + (xBase * scale); const yBase = centerY + (canvas.height - centerY) * scale; const yProj = yBase - (audioH * 72 * scale);
                if (z === 8) { ctx.moveTo(xProj, yProj); ctx.strokeStyle = `rgba(${audioH * 255}, ${255 - audioH * 45}, 200, ${scale * 0.9})`; } else { ctx.lineTo(xProj, yProj); }
