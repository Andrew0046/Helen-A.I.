}

function updateRecordStepDisplay() {
    const display = document.getElementById('recordStepDisplay');
    if (display) display.innerText = `REC STEP ${State.melody.recordStep + 1}`;
}

function recordMelodyNote(midi) {
    if (!State.melody.recordEnabled) return;
    const step = State.melody.recordStep;
    const existing = normalizeMelodyStep(melodyData[step]);
    if (State.melody.editMode === 'chord') {
        setMelodyStep(step, existing.includes(midi) ? existing : existing.concat(midi));
        updateStatus(`STEP REC: ${midiToName(midi)} ADDED TO STEP ${step + 1}`);
    } else {
        setMelodyStep(step, [midi]);
        State.melody.recordStep = (State.melody.recordStep + 1) % 16;
        updateStatus(`STEP REC: ${midiToName(midi)} CAPTURED`);
    }
    updateRecordStepDisplay();
    renderMelodyGrid();
    autoSave();
}

function startPianoElement(keyEl, shouldRecord = true) {
    if (!keyEl) return;
    playSynthNote(parseFloat(keyEl.dataset.freq), keyEl, audioCtx.currentTime, false, 118);
    if (shouldRecord) recordMelodyNote(parseInt(keyEl.dataset.midi, 10));
}

function stopPianoElement(keyEl) {
    if (!keyEl) return;
    releaseSynthNote(keyEl);
}

function togglePianoElement(keyEl) {
    if (!keyEl) return;
    if (latchedPianoElements.has(keyEl)) {
        stopPianoElement(keyEl);
        keyEl.classList.remove('latched');
        latchedPianoElements.delete(keyEl);
    } else {
        startPianoElement(keyEl, true);
        keyEl.classList.add('latched');
        latchedPianoElements.add(keyEl);
    }
}

function buildPianoKeyboard() {
    const pianoGrid = document.getElementById('pianoGrid');
    if (!pianoGrid) return;
    releaseAllPianoNotes();
    pianoGrid.innerHTML = '';
    pianoKeyElements = [];
    for (let i = 0; i < 25; i++) {
        const midi = pianoBaseMidi + i;
        const black = isBlackNote[midi % 12];
        const key = document.createElement('div');
        key.className = `key ${black ? 'black' : 'white'}`;
        key.dataset.freq = midiToFreq(midi).toFixed(2);
        key.dataset.midi = midi;
        key.dataset.index = i;
        const mapLabel = labelForPianoIndex(i);
        key.innerHTML = `<span class="key-note">${midiToName(midi)}</span><span class="key-map">${mapLabel}</span>`;
        key.title = `${midiToName(midi)} • ${Math.round(midiToFreq(midi))} Hz${mapLabel ? ` • Key ${mapLabel}` : ''}`;

        key.addEventListener('mousedown', (e) => {
            pianoMouseDown = true;
            e.preventDefault();
            if (pianoLatchEnabled) togglePianoElement(key);
            else startPianoElement(key, true);
        });
        key.addEventListener('mouseenter', (e) => {
            if (!pianoLatchEnabled && pianoMouseDown && e.buttons === 1) startPianoElement(key, false);
        });
        key.addEventListener('mouseup', () => { if (!pianoLatchEnabled) stopPianoElement(key); });
        key.addEventListener('mouseleave', () => { if (!pianoLatchEnabled && pianoMouseDown) stopPianoElement(key); });
        pianoKeyElements.push(key);
        pianoGrid.appendChild(key);
    }
    updateOctaveDisplay();
}

