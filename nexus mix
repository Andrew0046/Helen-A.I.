    }

    function scheduleLightPatternRender() {
        if (renderRAF) return;
        renderRAF = requestAnimationFrame(() => {
            renderRAF = null;
            // During song-chain playback, rebuilding the grids every bar causes stutters.
            // Only refresh the full grids when transport is stopped or after a manual/non-song pattern change.
            if (State?.sequencer?.isPlaying && isSongMode) {
                updatePatternButtons();
                return;
            }
            const now = stableNowMs();
            if (State?.sequencer?.isPlaying && now - lastPatternRender < 300) {
                updatePatternButtons();
                return;
            }
            try { renderSeqGrid(); } catch(e) {}
            try { if (typeof renderMelodyGrid === 'function') renderMelodyGrid(); } catch(e) {}
            try { if (typeof updateMelodyStepInspector === 'function') updateMelodyStepInspector(); } catch(e) {}
            lastPatternRender = now;
        });
    }

    const oldLoadPattern441 = loadPattern;
    loadPattern = function(letter) {
        if (!Patterns || !Patterns[letter]) return;
        const renderMode = State?.sequencer?.isPlaying ? 'defer' : 'now';
        const ok = assignPatternData(letter, renderMode);
        if (ok) safeStatus(`PATTERN ${letter} LOADED`);
        else if (typeof oldLoadPattern441 === 'function') oldLoadPattern441(letter);
    };

    function shouldPlayTrack(track) {
        const s = trackSettings?.[track];
        if (!s) return false;
        if (s.muted) return false;
        const anySolo = Object.values(trackSettings).some(t => t && t.solo);
        if (anySolo && !s.solo) return false;
        if (Math.random() > (s.prob ?? 1)) return false;
        return true;
    }

    function advanceStableSongChainAtBar() {
        if (!isSongMode || !Array.isArray(songChain) || songChain.length === 0) return true;
        if (stableSong.skipFirstBoundary) {
            stableSong.skipFirstBoundary = false;
            stableSong.barCount = 1;
            setSongText(`PLAYING ${songChain[songIndex] || currentPattern} • ${songIndex + 1}/${songChain.length}`);
            updateChainVisual(true);
            return true;
        }
        if (songIndex < songChain.length - 1) {
            songIndex++;
        } else {
            const loop = document.getElementById('songLoop')?.checked;
            if (loop) songIndex = 0;
            else {
                stopSongPlayback(true);
                safeStatus('SONG FINISHED');
                return false;
            }
        }
        const nextPattern = songChain[songIndex];
        assignPatternData(nextPattern, 'none');
        stableSong.barCount++;
        const looping = songIndex === 0 && stableSong.barCount > songChain.length;
        setSongText(`${looping ? 'LOOPING' : 'PLAYING'} ${nextPattern} • ${songIndex + 1}/${songChain.length}`);
        updateChainVisual();
        return true;
    }

    // Audio-only scheduler. This avoids calling the older chain wrapper that rebuilt the grid every bar.
    scheduleAudioEvents = function(step, time) {
        if (step === 0 && isSongMode) {
            const keepGoing = advanceStableSongChainAtBar();
            if (!keepGoing) return;
        }
        if (uiDrawQueue.length > 96) uiDrawQueue.splice(0, uiDrawQueue.length - 96);
        uiDrawQueue.push({ step, time });
        if (State.project?.metronome && typeof playMetronome === 'function') playMetronome(time, step === 0);
        const humanizeEl = document.getElementById('humanizeSlider');
        const humanize = humanizeEl ? parseFloat(humanizeEl.value) : 0;
        const jitter = (Math.random() - 0.5) * humanize * 0.012;

        if (seqData.kick?.[step] && shouldPlayTrack('kick')) playKick(time + jitter);
        if (seqData.snare?.[step] && shouldPlayTrack('snare')) playSnare(time + jitter);
        if (seqData.clap?.[step] && shouldPlayTrack('clap')) playClap(time + jitter);
        if (seqData.rim?.[step] && shouldPlayTrack('rim')) playRim(time + jitter);
        if (seqData.hat?.[step] && shouldPlayTrack('hat')) playHiHat(time + jitter);
        if (seqData.openhat?.[step] && shouldPlayTrack('openhat')) playOpenHat(time + jitter);
        if (seqData.tom?.[step] && shouldPlayTrack('tom')) playTom(time + jitter);
        if (seqData.perc?.[step] && shouldPlayTrack('perc')) playPerc(time + jitter);
        if (seqData.ride?.[step] && shouldPlayTrack('ride')) playRide(time + jitter);
        if (seqData.crash?.[step] && shouldPlayTrack('crash')) playCrash(time + jitter);
        if (seqData.samp?.[step] && shouldPlayTrack('samp')) playSample(time + jitter);

        try { if (typeof ensureMelodyMeta === 'function') ensureMelodyMeta(); } catch(e) {}
        const melodyNotes = (typeof normalizeMelodyStep === 'function') ? normalizeMelodyStep(melodyData[step]) : (melodyData[step] || []);
        if (melodyNotes.length) {
            const bpm = parseInt(document.getElementById('bpmSlider')?.value || State.sequencer.bpm || 128);
            const stepDuration = (60.0 / bpm) * 0.25;
            const meta = (typeof melodyStepMeta !== 'undefined' && melodyStepMeta[step]) ? melodyStepMeta[step] : { velocity: 112, gate: State.melody?.gate || .7 };
            State.melody.gateMs = Math.max(45, Math.min(1500, stepDuration * meta.gate * 1000));
            melodyNotes.forEach((midi, noteIndex) => {
                playSynthNote(midiToFreq(midi), null, time + jitter + noteIndex * 0.003, true, Math.max(25, meta.velocity - noteIndex * 5));
            });
        }

        const arpActive = document.getElementById('arpActive')?.checked;
        const arpMode = document.getElementById('arpMode')?.value;
        if (arpActive && arpMode !== 'off' && State.arp.notes.length > 0) {
            let nextIndex = State.arp.index;
            if (arpMode === 'up') nextIndex = (State.arp.index + 1) % State.arp.notes.length;
            else if (arpMode === 'down') nextIndex = (State.arp.index - 1 + State.arp.notes.length) % State.arp.notes.length;
            else if (arpMode === 'random') nextIndex = Math.floor(Math.random() * State.arp.notes.length);
            State.arp.index = nextIndex;
            const el = State.arp.notes[nextIndex];
            if (el && el.dataset.freq) playSynthNote(parseFloat(el.dataset.freq), el, time, true);
        }
    };

    masterClockLookahead = function() {
        const myGeneration = transportGeneration;
        if (!State.sequencer.isPlaying || myGeneration !== transportGeneration) {
            clearTimeout(timerID);
            timerID = null;
            return;
        }
        const now = audioCtx.currentTime;
        if (State.sequencer.nextNoteTime < now - 0.22) {
            State.sequencer.nextNoteTime = now + 0.025;
            safeStatus('TRANSPORT RECOVERED');
        }
        let scheduled = 0;
        while (State.sequencer.isPlaying && myGeneration === transportGeneration && State.sequencer.nextNoteTime < audioCtx.currentTime + 0.075 && scheduled < 5) {
            scheduleAudioEvents(State.sequencer.currentStep, State.sequencer.nextNoteTime);
            if (!State.sequencer.isPlaying) break;
            scheduleNextStep();
            scheduled++;
        }
        if (scheduled >= 5) State.sequencer.nextNoteTime = audioCtx.currentTime + 0.025;
        activeVoices = activeVoices.filter(v => v && !v.isKilled);
        if (activeVoices.length > 18) {
            const extras = activeVoices.splice(0, activeVoices.length - 18);
            extras.forEach(v => { try { stopVoiceProcess(v, audioCtx.currentTime, 0.018); } catch(e) {} });
        }
