        const durSec = Math.max(0.16, (end - start) / src.sampleRate);
        const slice = durSec / 8;
        for (let i=0; i<8; i++) {
            ref.V.slots[i] = { buffer: src, start: startSec + i * slice, duration: Math.max(0.045, slice), name: `Smart ${i + 1}` };
