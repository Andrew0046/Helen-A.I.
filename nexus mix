        if (id === 'reverbMix' && Engine.revGain) Engine.revGain.gain.value = v;
        if (id === 'delayMix' && Engine.delGain) Engine.delGain.gain.value = v;
        if (id === 'chorusMix' && Engine.chorusGain) Engine.chorusGain.gain.value = v;
