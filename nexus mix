        el.dispatchEvent(new Event(el.type === 'range' ? 'input' : 'change', { bubbles: true }));
    };

    function syncMixerValue(id, value) {
        const v = Number(value);
        if (!Number.isFinite(v)) return;
        if (State.mixer && Object.prototype.hasOwnProperty.call(State.mixer, id)) State.mixer[id] = v;
        if (State.synth && Object.prototype.hasOwnProperty.call(State.synth, id)) State.synth[id] = v;
        if (id === 'volSynth' && Engine.synthMix) Engine.synthMix.gain.value = v;
