    function scheduleOfflineVoice47(ctx, dest, sections, bpm){
        const V = window.NexusVoiceLab;
        if (!V?.slots?.some(s => s?.buffer) || !V?.seq) return;
        const stepDur = (60 / bpm) * 0.25;
        let t = 0;
        const vol = clamp47(V.settings?.vol ?? $('v45VoiceVol')?.value ?? 0.75, 0, 1.2) * 0.72;
        const pitch = clamp47(V.settings?.pitch ?? $('v45VoicePitch')?.value ?? 1, 0.35, 2.5);
        const filterFreq = clamp47(V.settings?.filter ?? $('v45VoiceFilter')?.value ?? 10000, 120, 18000);
        const gate = clamp47(V.settings?.gate ?? $('v45VoiceGate')?.value ?? 0.85, 0.1, 1.5);
        for (const sec of sections) {
            for (let bar=0; bar<(sec.bars || 1); bar++) {
                for (let step=0; step<16; step++) {
                    const time = t + step * stepDur;
                    for (let row=0; row<8; row++) {
                        if (!V.seq?.[row]?.[step]) continue;
                        const slot = V.slots[row];
                        if (!slot?.buffer) continue;
                        try {
                            const src = ctx.createBufferSource();
                            src.buffer = slot.buffer;
                            src.playbackRate.value = pitch;
                            const filter = ctx.createBiquadFilter(); filter.type = 'lowpass'; filter.frequency.value = filterFreq; filter.Q.value = 0.8;
                            const amp = ctx.createGain();
                            const pan = ctx.createStereoPanner ? ctx.createStereoPanner() : ctx.createGain();
                            if (pan.pan) pan.pan.value = ((row % 4) - 1.5) * 0.10;
                            const dur = Math.max(0.035, Math.min(slot.duration || slot.buffer.duration, stepDur * 3.5) * gate);
                            amp.gain.setValueAtTime(0.0001, time);
                            amp.gain.linearRampToValueAtTime(vol, time + 0.006);
                            amp.gain.setValueAtTime(vol * 0.92, time + Math.max(0.01, dur * 0.72));
                            amp.gain.linearRampToValueAtTime(0.0001, time + dur + 0.03);
                            src.connect(filter); filter.connect(amp); amp.connect(pan); pan.connect(dest);
                            src.start(time, slot.start || 0, dur);
                            src.stop(time + dur + 0.05);
                        } catch(e) { console.warn('voice offline event skipped', e); }
                    }
                }
                t += 16 * stepDur;
