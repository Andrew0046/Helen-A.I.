        if (arpActive && !isArp) {
            if (element && !State.arp.notes.includes(element)) State.arp.notes.push(element);
            if (!State.sequencer.isPlaying && $('playSeqBtn')) $('playSeqBtn').click();
            return;
        }
        activeVoices = activeVoices.filter(v => v && !v.isKilled);
        const maxVoices = 18;
        if (activeVoices.length >= maxVoices) { const oldest = activeVoices[0]; if (oldest) stopVoiceProcess(oldest, time, 0.01); }
        if (element) {
            element.classList.add('active');
            const readout = $('currentFreqDisplay'); if (readout) readout.innerText = Math.round(freq);
            element.style.boxShadow = element.classList.contains('key') ? '0 0 25px var(--neon-primary), inset 0 0 15px rgba(0,255,204,0.6)' : '0 0 22px var(--neon-accent), inset 0 0 12px rgba(170,0,255,0.5)';
            setTimeout(() => { if (element) element.style.boxShadow = ''; }, 180);
        }
        try { triggerVisualEvent('synth', 0.65 + (velocity/220)); } catch(e) {}

        const noteGain = audioCtx.createGain();
        const voiceInput = audioCtx.createGain();
        const noteFilter = audioCtx.createBiquadFilter();
        const voiceDrive = audioCtx.createWaveShaper();
        const bit = audioCtx.createWaveShaper();
        const phaser = audioCtx.createBiquadFilter();
        phaser.type = 'allpass'; phaser.frequency.value = 650 + p.synthPhaser*3600; phaser.Q.value = .4 + p.synthPhaser*7;
        noteFilter.type = getFilterType(p.filterType);
        noteFilter.Q.value = (p.filterType === 'acid' ? p.filterRes * 1.9 : p.filterRes);
        const baseCut = clamp((State.synth.filterCutoff || 6500) * (.45 + p.macroBrightness*.95), 45, 16000);
        const envTop = clamp(baseCut * (1 + p.filterEnv*2.2), 55, 19000);
        const envBottom = clamp(baseCut * (.35 + p.macroBrightness*.25), 45, 15000);
        noteFilter.frequency.setValueAtTime(envBottom, time);
        noteFilter.frequency.exponentialRampToValueAtTime(envTop, time + Math.max(.006, State.synth.atk || .04));
        noteFilter.frequency.exponentialRampToValueAtTime(baseCut, time + Math.max(.05, (State.synth.atk||.04)+(State.synth.dec||.22)));
        voiceDrive.curve = makeVoiceDriveCurve(clamp(p.filterDrive + p.macroAggression*.22, 0, 1));
        bit.curve = makeBitcrushCurve(clamp(p.bitcrush + p.macroAggression*.04, 0, 1));
        const a = Math.max(.002, State.synth.atk || .05);
        const d = Math.max(.02, State.synth.dec || .22);
        const s = clamp(State.synth.sus ?? .6, 0, 1);
        const velMod = clamp(velocity/127, .05, 1.3);
        noteGain.gain.setValueAtTime(.0001, time);
        noteGain.gain.linearRampToValueAtTime(clamp(.78 * velMod * (1+p.macroAggression*.18), .02, 1.05), time + a);
        noteGain.gain.linearRampToValueAtTime(clamp(s * velMod, .0001, 1), time + a + d);
        voiceInput.connect(noteFilter); noteFilter.connect(phaser); phaser.connect(voiceDrive); voiceDrive.connect(bit); bit.connect(noteGain); noteGain.connect(Engine.sidechain);
        let voice = { noteGain, element, freq, isKilled:false, oscs:[] };

        const mode = $('synthMode')?.value || 'lead';
        const chordMode = $('chordMode')?.checked;
        const freqTargets = (chordMode && !isArp) ? [[freq,1],[freq*1.2599,.64],[freq*1.4983,.58]] : [[freq,1]];
        const addLayer = (baseFreq, gainMod=1) => {
            const glide = Math.max(0, p.glide || 0);
            const startFreq = glide > 0 && V49.lastFreq ? V49.lastFreq : baseFreq;
            const unisonCount = Math.max(1, Math.round(p.unison || 1));
            const osc1Mix = 1 - clamp(p.oscMix,0,1);
            const osc2Mix = clamp(p.oscMix,0,1);
            const addOsc = (wave, targetFreq, level, detuneCents, panVal) => {
                if (level <= .001) return;
                const osc = audioCtx.createOscillator(); osc.type = wave; osc.frequency.setValueAtTime(startFreq, time);
                if (glide > .001) osc.frequency.exponentialRampToValueAtTime(Math.max(12, targetFreq), time + glide); else osc.frequency.setValueAtTime(targetFreq, time);
                osc.detune.value = detuneCents;
                if (p.vibratoDepth > .001 || p.macroMovement > .001) {
                    const lfo = audioCtx.createOscillator(); const lfoGain = audioCtx.createGain();
                    lfo.frequency.value = p.vibratoRate || 5;
                    lfoGain.gain.value = (p.vibratoDepth*55) + (p.macroMovement*8);
                    lfo.connect(lfoGain); lfoGain.connect(osc.detune); lfo.start(time); lfo.stop(time + 8);
                    voice.oscs.push(lfo);
                }
                const g = audioCtx.createGain(); g.gain.value = level * gainMod;
                if (audioCtx.createStereoPanner) {
                    const pan = audioCtx.createStereoPanner(); pan.pan.value = clamp(panVal, -1, 1);
                    osc.connect(g); g.connect(pan); pan.connect(voiceInput);
                } else { osc.connect(g); g.connect(voiceInput); }
                osc.start(time); voice.oscs.push(osc);
            };
            const spread = clamp(p.stereo + p.widener*.5, 0, 1);
            for (let i=0;i<unisonCount;i++) {
                const centered = unisonCount === 1 ? 0 : (i/(unisonCount-1))*2 - 1;
                const cents = centered * (p.unisonDetune || 0);
                const pan = centered * spread;
                const levelScale = 1 / Math.sqrt(unisonCount);
                addOsc(p.osc1Wave, baseFreq, .62 * osc1Mix * levelScale, cents, pan);
                const semi = Number(p.osc2Semi)||0;
                const det = Number(p.osc2Detune)||0;
                addOsc(p.osc2Wave, baseFreq * Math.pow(2, semi/12), .62 * osc2Mix * levelScale, cents + det, -pan*.75);
            }
            if (p.subLevel > .005 || mode === 'bass') {
                addOsc('sine', baseFreq * .5, clamp(p.subLevel + (mode==='bass'?.18:0),0,1) * .75, 0, 0);
            }
            if (p.noiseLevel > .002 || mode === 'hybrid') {
                const noise = audioCtx.createBufferSource(); noise.buffer = Engine.noiseBuffer;
                const nf = audioCtx.createBiquadFilter(); nf.type = p.filterType === 'formant' ? 'bandpass' : 'highpass'; nf.frequency.value = baseFreq * (p.filterType === 'formant' ? 2.7 : 3.5); nf.Q.value = 1 + p.synthPhaser*5;
                const ng = audioCtx.createGain(); ng.gain.value = clamp(p.noiseLevel + (mode==='hybrid'?.035:0),0,.8) * gainMod * velMod;
                noise.connect(nf); nf.connect(ng); ng.connect(voiceInput); noise.start(time); noise.stop(time + 5); voice.oscs.push(noise);
            }
        };
        freqTargets.forEach(([f,g]) => addLayer(f,g));
        V49.lastFreq = freq;
        activeVoices.push(voice);
        if (isArp) {
            const bpm = parseInt($('bpmSlider')?.value || '128', 10);
            const stepDuration = (60/bpm)*.25;
            const gate = Math.max(45, Math.min(1600, stepDuration * (p.arpGate || .65) * 1000));
            setTimeout(() => { if (voice && !voice.isKilled) stopVoiceProcess(voice, audioCtx.currentTime, .045); }, gate);
        }
    }

    function enhancedArpStep(time){
        const p = ensureState();
        const notes = State.arp.notes || [];
        if (!$('arpActive')?.checked || notes.length === 0) return;
        const mode = $('arpMode')?.value || 'up';
        const div = p.arpDivision || '1/16';
        const step = State.sequencer.currentStep || 0;
        if (div === '1/4' && step % 4 !== 0) return;
        if (div === '1/8' && step % 2 !== 0) return;
        let nextIndex = State.arp.index || 0;
        if (mode === 'up') nextIndex = (nextIndex + 1) % notes.length;
        else if (mode === 'down') nextIndex = (nextIndex - 1 + notes.length) % notes.length;
        else if (mode === 'random') nextIndex = Math.floor(Math.random() * notes.length);
        else if (mode === 'updown') {
            if (!State.arp.direction) State.arp.direction = 1;
            nextIndex += State.arp.direction;
            if (nextIndex >= notes.length) { State.arp.direction = -1; nextIndex = Math.max(0, notes.length - 2); }
            if (nextIndex < 0) { State.arp.direction = 1; nextIndex = Math.min(1, notes.length - 1); }
        }
        State.arp.index = nextIndex;
        const el = notes[nextIndex];
        if (!el || !el.dataset.freq) return;
        const octaves = Math.max(1, Math.round(p.arpOctaves || 1));
        const octave = octaves <= 1 ? 0 : Math.floor((step / 2) % octaves);
        const f = parseFloat(el.dataset.freq) * Math.pow(2, octave);
        enhancedPlaySynthNote(f, el, time, true, 104);
        try { if (visualMode !== 'spectrum' && Math.random() < .7) triggerVisualEvent('synth', .45); } catch(e) {}
    }

    function installSynthEngine(){
        if (window.__nexusV49EngineInstalled) return;
        window.__nexusV49EngineInstalled = true;
        V49.oldPlaySynthNote = typeof playSynthNote === 'function' ? playSynthNote : null;
        try { playSynthNote = enhancedPlaySynthNote; window.playSynthNote = enhancedPlaySynthNote; } catch(e) { window.playSynthNote = enhancedPlaySynthNote; }
        if (typeof scheduleAudioEvents === 'function') {
            const oldSchedule = scheduleAudioEvents;
            scheduleAudioEvents = function(step, time){
                const proOn = ensureState().enabled;
                const arpEl = $('arpMode');
                const suppressArp = proOn && $('arpActive')?.checked && State.arp.notes && State.arp.notes.length;
                const oldVal = arpEl ? arpEl.value : null;
                if (suppressArp && arpEl) arpEl.value = 'off';
                oldSchedule(step, time);
                if (suppressArp && arpEl) arpEl.value = oldVal;
                if (suppressArp) enhancedArpStep(time);
            };
            window.scheduleAudioEvents = scheduleAudioEvents;
        }
    }

    function auditionSynthPro(){
        initAudio();
        const now = audioCtx.currentTime + .03;
        const root = 48 + [0,3,7,10][Math.floor(Math.random()*4)];
        [root, root+7, root+12].forEach((m,i) => enhancedPlaySynthNote(440*Math.pow(2,(m-69)/12), null, now + i*.13, true, 108 - i*6));
        safeStatus('SYNTH LAB PRO AUDITION');
    }

    function drawMiniWaveform(){
        const canvas = $('v49WaveCanvas'); if (!canvas) return;
        const ctx = canvas.getContext('2d'); const p=ensureState();
        const w=canvas.width, h=canvas.height; ctx.clearRect(0,0,w,h);
        ctx.fillStyle = '#020202'; ctx.fillRect(0,0,w,h);
        ctx.strokeStyle = 'rgba(0,255,204,.16)'; ctx.lineWidth = 1;
        for (let x=0;x<w;x+=24){ ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,h); ctx.stroke(); }
        ctx.strokeStyle = 'rgba(0,255,204,.95)'; ctx.lineWidth = 2; ctx.beginPath();
        for (let x=0;x<w;x++){
            const t = x/w * Math.PI*4;
            let y = Math.sin(t);
            if (p.osc1Wave === 'square') y = y >= 0 ? 1 : -1;
            if (p.osc1Wave === 'sawtooth') y = 2*((t/(Math.PI*2))%1)-1;
            if (p.osc1Wave === 'triangle') y = 2*Math.abs(2*((t/(Math.PI*2))%1)-1)-1;
            const y2 = Math.sin(t * Math.pow(2,(Number(p.osc2Semi)||0)/12) + (Number(p.osc2Detune)||0)/25);
            const mixed = y*(1-p.oscMix) + y2*p.oscMix + Math.sin(t*.5)*p.subLevel*.35;
            const yy = h/2 - mixed * (h*.28 + p.macroAggression*8);
            if (x===0) ctx.moveTo(x, yy); else ctx.lineTo(x, yy);
        }
        ctx.stroke();
        ctx.fillStyle = 'rgba(255,255,255,.52)'; ctx.font = '10px Courier New';
        ctx.fillText(`${(p.lastPatch||'Init Pro')} • ${p.unison}x unison • ${p.filterType}`, 10, h-10);
    }

    function installProjectHooks(){
        if (window.__nexusV49ProjectHooksInstalled) return; window.__nexusV49ProjectHooksInstalled = true;
        if (typeof applyProjectSnapshot === 'function') {
            const oldApply = applyProjectSnapshot;
            applyProjectSnapshot = function(snap){
                oldApply(snap);
                if (snap?.state?.synthPro) Object.assign(ensureState(), snap.state.synthPro);
                if (snap?.v49?.synthPro) Object.assign(ensureState(), snap.v49.synthPro);
                syncUIFromState(); applyMacroRouting();
            };
            window.applyProjectSnapshot = applyProjectSnapshot;
        }
        if (typeof captureProjectSnapshot === 'function') {
            const oldCapture = captureProjectSnapshot;
            captureProjectSnapshot = function(){
                const snap = oldCapture();
                snap.v49 = { synthPro: JSON.parse(JSON.stringify(ensureState())) };
                if (snap.state) snap.state.synthPro = JSON.parse(JSON.stringify(ensureState()));
                snap.version = '4.9';
                return snap;
            };
            window.captureProjectSnapshot = captureProjectSnapshot;
        }
    }

    function boot(){
        try {
            ensureState(); installStyles(); createSynthLabPanel(); wireUI(); installSynthEngine(); installProjectHooks(); syncUIFromState(); applyMacroRouting();
            const brand = document.querySelector('.branding'); if (brand) brand.textContent = 'NEXUS STUDIO';
            const version = document.querySelector('.version'); if (version) version.textContent = 'PRO v4.9 • SYNTH LAB PRO';
            document.title = 'NEXUS STUDIO PRO v4.9 — Synth Lab Pro';
            safeStatus('v4.9 SYNTH LAB PRO READY');
            V49.installed = true;
        } catch(err) { console.error('v4.9 boot warning', err); safeStatus('v4.9 BOOT WARNING'); }
    }

    const previousOnload49 = window.onload;
    window.onload = function(...args){
        if (typeof previousOnload49 === 'function') previousOnload49.apply(this, args);
        boot();
    };
})();
</script>

