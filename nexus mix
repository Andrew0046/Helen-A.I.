    };

    function clearStepHighlights() {
        try { document.querySelectorAll('.current-col').forEach(el => el.classList.remove('current-col')); } catch(e) {}
    }

    function startTransport() {
        initAudio();
        clearTimeout(timerID);
        transportGeneration++;
        if (audioCtx.state === 'suspended') audioCtx.resume();
        State.sequencer.isPlaying = true;
        State.sequencer.currentStep = 0;
        State.sequencer.nextNoteTime = audioCtx.currentTime + 0.045;
        updateTransportButton(true);
