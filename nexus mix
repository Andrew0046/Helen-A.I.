<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXUS STUDIO PRO v4.9 — Synth Lab Pro</title>
    <style>
        :root {
            --bg-deep: #050505;
            --panel-bg: #0a0a0a;
            --border-color: #222;
            --neon-primary: #00ffcc;
            --neon-secondary: #ff0055;
            --neon-accent: #aa00ff;
            --text-main: #eee;
            --text-dim: #777;
            --warning: #ffaa00;
        }

        body { 
            margin: 0; 
            background-color: var(--bg-deep); 
            color: var(--text-main); 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            justify-content: center; 
            min-height: 100vh; 
            font-family: 'Courier New', Courier, monospace; 
            user-select: none; 
            padding: 15px; 
            overflow-x: hidden; 
        }
        
        .studio-container { 
            background: #111; 
            padding: 20px; 
            border-radius: 16px; 
            box-shadow: 0 0 120px rgba(0, 255, 204, 0.12); 
            border: 1px solid #333; 
            width: 100%; 
            max-width: 1180px; 
            display: flex; 
            flex-direction: column; 
            gap: 16px; 
            position: relative; 
        }
        
        .top-bar { 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 12px 20px; background: var(--panel-bg); border: 1px solid var(--border-color); 
            border-radius: 12px; box-shadow: inset 0 0 20px rgba(0,0,0,0.8); 
        }
        .branding { font-size: 22px; font-weight: bold; color: var(--text-main); text-transform: uppercase; letter-spacing: 5px; text-shadow: 0 0 12px rgba(0,255,204,0.4); }
        .version { font-size: 10px; color: #444; margin-left: 8px; }
        .status-cluster { display: flex; gap: 16px; align-items: center; font-size: 13px; }
        .readout { font-size: 13px; color: var(--neon-primary); font-weight: bold; background: #000; padding: 2px 10px; border-radius: 4px; border: 1px solid #333; }
        .midi-status { font-size: 11px; padding: 5px 11px; border-radius: 6px; background: #222; border: 1px solid #444; color: #888; letter-spacing: 1px; }
        .midi-status.active { border-color: var(--neon-primary); color: var(--neon-primary); box-shadow: 0 0 12px rgba(0,255,204,0.4); }
        
        .sys-btns { display: flex; gap: 8px; flex-wrap: wrap; }
        .sys-btn { background: #222; color: #fff; border: 1px solid #555; padding: 7px 14px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: all 0.15s; font-family: inherit; font-size: 11px; }
        .sys-btn:hover { background: #333; border-color: var(--neon-primary); }
        .sys-btn:active { transform: scale(0.96); }
        .record-btn { border-color: var(--neon-secondary); color: var(--neon-secondary); }
        .record-btn.recording { background: var(--neon-secondary); color: #fff; box-shadow: 0 0 18px var(--neon-secondary); animation: pulse 1s infinite; }
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.6; } 100% { opacity: 1; } }
        .panic-btn { background: var(--warning); color: #000; border: none; font-weight: bold; }

        .tab-nav { display: flex; gap: 8px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; }
        .tab-btn { background: transparent; color: var(--text-dim); border: none; font-size: 13px; font-weight: bold; font-family: inherit; cursor: pointer; padding: 9px 18px; text-transform: uppercase; letter-spacing: 2px; transition: all 0.2s; position: relative; }
        .tab-btn:hover { color: var(--text-main); }
        .tab-btn.active { color: var(--neon-primary); }
        .tab-btn.active::after { content: ''; position: absolute; bottom: -10px; left: 0; width: 100%; height: 2px; background: var(--neon-primary); box-shadow: 0 -2px 10px var(--neon-primary); }
        
        .tab-content { display: none; animation: fadeIn 0.25s ease-out; }
        .tab-content.active { display: flex; flex-direction: column; gap: 16px; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

        .panel { background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 16px; box-sizing: border-box; box-shadow: inset 0 0 25px rgba(0,0,0,0.6); }
        .panel-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #222; padding-bottom: 12px; margin-bottom: 14px; flex-wrap: wrap; gap: 10px; }
        .panel-title { color: var(--text-dim); font-size: 11px; text-transform: uppercase; letter-spacing: 3px; }

        .control-group { display: flex; align-items: center; gap: 10px; background: #000; padding: 8px 12px; border-radius: 7px; border: 1px solid #333; flex-wrap: wrap; }
        select { background: #111; color: var(--neon-primary); border: 1px solid #444; padding: 6px 8px; border-radius: 5px; font-family: inherit; font-weight: bold; cursor: pointer; outline: none; font-size: 12px; }

        .knob-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 18px; }
        .knob-container { display: flex; flex-direction: column; align-items: center; gap: 6px; position: relative; }
        .knob-label { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }
        .knob-readout { font-size: 10px; color: var(--neon-primary); font-weight: bold; background: #000; padding: 2px 7px; border-radius: 3px; border: 1px solid #333; min-width: 46px; text-align: center; }
        .knob { width: 48px; height: 48px; border-radius: 50%; background: conic-gradient(from 225deg, #333 0%, #111 75%, transparent 75%); position: relative; border: 2px solid #000; box-shadow: 0 4px 10px rgba(0,0,0,0.8), inset 0 2px 4px rgba(255,255,255,0.1); cursor: ns-resize; transform: rotate(-135deg); transition: box-shadow 0.1s; }
        .knob:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.9), inset 0 2px 4px rgba(255,255,255,0.15), 0 0 8px rgba(0,255,204,0.2); }
        .knob-indicator { width: 3.5px; height: 11px; background: var(--neon-primary); position: absolute; top: 4px; left: 50%; transform: translateX(-50%); border-radius: 2px; box-shadow: 0 0 7px var(--neon-primary); }
        .knob-center { width: 32px; height: 32px; background: #1a1a1a; border-radius: 50%; position: absolute; top: 7px; left: 7px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.85); }

        .mixer-grid { display: flex; justify-content: space-around; padding: 8px 0; }
        .fader-group { display: flex; flex-direction: column; align-items: center; gap: 8px; }
        .fader { -webkit-appearance: slider-vertical; width: 22px; height: 110px; accent-color: var(--neon-primary); background: #000; border-radius: 10px; outline: none; }
        .fader.drum-fader { accent-color: var(--neon-secondary); } .fader.rev-fader { accent-color: var(--neon-accent); }

        .drums-live { display: flex; gap: 10px; width: 100%; margin-bottom: 14px; flex-wrap: wrap; }
        .drum-pad { flex: 1; min-width: 70px; background: #151515; border: 2px solid #333; border-radius: 7px; padding: 10px 6px; text-align: center; font-size: 10px; font-weight: bold; color: var(--text-dim); cursor: pointer; transition: all 0.08s ease-out; box-shadow: inset 0 -3px 8px rgba(0,0,0,0.6); }
        .drum-pad:active, .drum-pad.active { transform: translateY(1px); box-shadow: inset 0 1px 4px rgba(0,0,0,0.8); color: #fff; }
        .dp-kick:active, .dp-kick.active { border-color: var(--neon-secondary); background: rgba(255,0,85,0.18); text-shadow: 0 0 8px var(--neon-secondary); }
        .dp-snare:active, .dp-snare.active { border-color: var(--neon-primary); background: rgba(0,255,204,0.18); text-shadow: 0 0 8px var(--neon-primary); }
        .dp-hat:active, .dp-hat.active { border-color: #ffca28; background: rgba(255,202,40,0.18); text-shadow: 0 0 8px #ffca28; }
        .dp-tom:active, .dp-tom.active { border-color: var(--neon-accent); background: rgba(170,0,255,0.18); text-shadow: 0 0 8px var(--neon-accent); }
        .dp-crash:active, .dp-crash.active { border-color: #fff; background: rgba(255,255,255,0.15); text-shadow: 0 0 8px #fff; }
        .dp-clap:active, .dp-clap.active { border-color: #ff66cc; background: rgba(255,102,204,0.18); text-shadow: 0 0 8px #ff66cc; }
        .dp-rim:active, .dp-rim.active { border-color: #66ccff; background: rgba(102,204,255,0.18); text-shadow: 0 0 8px #66ccff; }
        .dp-openhat:active, .dp-openhat.active { border-color: #ffe066; background: rgba(255,224,102,0.18); text-shadow: 0 0 8px #ffe066; }
        .dp-ride:active, .dp-ride.active { border-color: #b8ff66; background: rgba(184,255,102,0.18); text-shadow: 0 0 8px #b8ff66; }
        .dp-perc:active, .dp-perc.active { border-color: #ff8844; background: rgba(255,136,68,0.18); text-shadow: 0 0 8px #ff8844; }

        .drum-tools { display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin-top: 10px; }
        .mini-drum-btn { background:#171717; color:#ddd; border:1px solid #444; padding:6px 10px; border-radius:5px; font-size:10px; font-family:inherit; font-weight:bold; cursor:pointer; transition:all .12s; }
        .mini-drum-btn:hover { border-color: var(--neon-primary); color: var(--neon-primary); }
        .mini-drum-btn.danger:hover { border-color: var(--neon-secondary); color: var(--neon-secondary); }
        
        .sampler-drop { border: 2px dashed #444; background: #0a0a0a; color: #666; border-radius: 7px; display: flex; align-items: center; justify-content: center; padding: 10px; font-size: 9px; cursor: pointer; transition: all 0.2s; flex: 1.3; min-width: 120px; text-align: center; }
        .sampler-drop.dragover { border-color: var(--neon-primary); background: #111; color: var(--neon-primary); }
        .sampler-drop.loaded { border-style: solid; border-color: var(--neon-primary); color: var(--neon-primary); text-shadow: 0 0 8px var(--neon-primary); }

        .seq-with-controls { display: flex; flex-direction: column; gap: 10px; background: #000; padding: 10px; border-radius: 8px; border: 1px solid #222; }
        .seq-grid { display: grid; grid-template-columns: auto repeat(16, 1fr); gap: 5px; align-items: center; }
        .seq-label { font-size: 9px; color: var(--text-dim); font-weight: bold; text-align: right; padding-right: 8px; }
        .seq-step { aspect-ratio: 1/1; background: #1a1a1a; border: 1px solid #333; border-radius: 4px; cursor: pointer; transition: background 0.1s, transform 0.1s; }
        .seq-step:hover { background: #2a2a2a; }
        .seq-step.active-kick { background: var(--neon-secondary); border-color: var(--neon-secondary); box-shadow: 0 0 10px rgba(255,0,85,0.6); }
        .seq-step.active-snare { background: var(--neon-primary); border-color: var(--neon-primary); box-shadow: 0 0 10px rgba(0,255,204,0.6); }
        .seq-step.active-hat { background: #ffca28; border-color: #ffca28; box-shadow: 0 0 10px rgba(255,202,40,0.6); }
        .seq-step.active-tom { background: var(--neon-accent); border-color: var(--neon-accent); box-shadow: 0 0 10px rgba(170,0,255,0.6); }
        .seq-step.active-crash { background: #fff; border-color: #fff; box-shadow: 0 0 10px rgba(255,255,255,0.6); }
        .seq-step.active-samp { background: var(--neon-primary); border-color: var(--neon-primary); }
        .seq-step.active-clap { background: #ff66cc; border-color: #ff66cc; box-shadow: 0 0 10px rgba(255,102,204,0.6); }
        .seq-step.active-rim { background: #66ccff; border-color: #66ccff; box-shadow: 0 0 10px rgba(102,204,255,0.6); }
        .seq-step.active-openhat { background: #ffe066; border-color: #ffe066; box-shadow: 0 0 10px rgba(255,224,102,0.6); }
        .seq-step.active-ride { background: #b8ff66; border-color: #b8ff66; box-shadow: 0 0 10px rgba(184,255,102,0.6); }
        .seq-step.active-perc { background: #ff8844; border-color: #ff8844; box-shadow: 0 0 10px rgba(255,136,68,0.6); }
        .seq-step.current-col { border: 2px solid #fff; transform: scale(1.12); z-index: 10; box-shadow: 0 0 16px rgba(255,255,255,0.85); }

        /* THE MISSING TRACK CONTROLS CSS */
        .track-controls { display: grid; grid-template-columns: auto repeat(16, 1fr); gap: 5px; margin-bottom: 5px; }
        .track-control-row { grid-column: 1 / -1; display: grid; grid-template-columns: 40px 100px 30px 30px 100px; gap: 8px; align-items: center; padding: 4px; background: #111; border-radius: 4px; }
        .track-label { font-size: 9px; color: var(--text-dim); font-weight: bold; text-align: right; }
        .track-vol, .track-prob { width: 100%; accent-color: var(--neon-primary); }
        .track-btn { background: #222; border: 1px solid #444; color: #666; font-size: 9px; font-weight: bold; padding: 4px 0; text-align: center; border-radius: 3px; cursor: pointer; transition: all 0.1s; }
        .track-btn.mute.active { background: var(--neon-secondary); color: #fff; border-color: var(--neon-secondary); text-shadow: 0 0 5px #fff; }
        .track-btn.solo.active { background: #ffca28; color: #000; border-color: #ffca28; }

        .pattern-row { display: flex; gap: 6px; align-items: center; margin-bottom: 12px; flex-wrap: wrap; }
        .pattern-btn { background: #1a1a1a; color: #888; border: 1px solid #444; padding: 6px 13px; border-radius: 5px; font-weight: bold; font-size: 12px; cursor: pointer; transition: all 0.15s; min-width: 32px; text-align: center; }
        .pattern-btn.active { background: var(--neon-primary); color: #000; border-color: var(--neon-primary); box-shadow: 0 0 10px rgba(0,255,204,0.5); }
        .pattern-btn:hover:not(.active) { border-color: #666; color: #ccc; }

        .song-chain { background: #000; border: 1px solid #333; border-radius: 8px; padding: 10px 12px; margin-top: 8px; }
        .song-chain-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; }
        .chain-list { display: flex; gap: 6px; flex-wrap: wrap; min-height: 36px; align-items: center; }
        .chain-item { background: #222; color: var(--neon-primary); border: 1px solid #444; padding: 4px 10px; border-radius: 4px; font-weight: bold; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 6px; }
        .chain-item:hover { border-color: var(--neon-primary); }
        .chain-item .remove { color: var(--neon-secondary); font-size: 11px; cursor: pointer; padding: 0 2px; }
        /* v4.3.1 Song Chain Stability */
        .chain-list { max-height: 118px; overflow-y: auto; align-content: flex-start; padding-right: 4px; scroll-behavior: smooth; }
        .chain-list::-webkit-scrollbar { width: 6px; }
        .chain-list::-webkit-scrollbar-thumb { background: #333; border-radius: 999px; }
        .chain-item { position: relative; min-width: 34px; justify-content: center; }
        .chain-item::before { content: attr(data-num); color: #555; font-size: 8px; margin-right: 2px; }
        .chain-item.playing { background: var(--neon-primary); color: #000; border-color: var(--neon-primary); box-shadow: 0 0 12px rgba(0,255,204,0.55); }
        .chain-item.playing .remove { color: #000; opacity: 0.65; }
        .chain-count { color: #666; font-size: 9px; margin-left: 8px; }
        
        .song-controls { display: flex; gap: 8px; align-items: center; margin-top: 8px; flex-wrap: wrap; }
        .song-btn { background: #222; color: #fff; border: 1px solid #555; padding: 5px 12px; border-radius: 5px; font-size: 11px; cursor: pointer; font-weight: bold; }
        .song-btn.play { background: var(--neon-accent); color: #000; border-color: var(--neon-accent); }


        .track-fx-panel { margin-top: 14px; }
        .fx-toolbar { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
        .fx-table { display:flex; flex-direction:column; gap:6px; background:#000; border:1px solid #222; border-radius:10px; padding:10px; overflow-x:auto; }
        .fx-row { display:grid; grid-template-columns: 70px repeat(6, minmax(92px, 1fr)) 58px; gap:7px; align-items:center; min-width:900px; padding:6px; border-radius:6px; background:#0d0d0d; border:1px solid #1f1f1f; }
        .fx-row.fx-head { background:#050505; border-color:#333; color:#666; font-size:9px; text-transform:uppercase; letter-spacing:1px; font-weight:bold; }
        .fx-track-name { color:var(--neon-primary); font-size:10px; font-weight:bold; text-align:right; padding-right:4px; }
        .fx-cell { display:flex; flex-direction:column; gap:3px; color:#666; font-size:8px; text-transform:uppercase; letter-spacing:1px; }
        .fx-cell input[type=range] { width:100%; accent-color:var(--neon-primary); }
        .fx-cell.drive input[type=range] { accent-color:var(--neon-secondary); }
        .fx-cell.send input[type=range] { accent-color:var(--neon-accent); }
        .fx-value { color:#aaa; font-size:9px; min-height:10px; }
        .fx-reset { background:#191919; color:#888; border:1px solid #444; border-radius:5px; padding:5px 0; font-size:9px; font-family:inherit; font-weight:bold; cursor:pointer; }
        .fx-reset:hover { color:#fff; border-color:var(--neon-secondary); }

        .performance-area { display: flex; flex-direction: column; gap: 14px; }
        .piano-module, .melody-panel { background: #000; border: 1px solid #333; border-radius: 10px; padding: 12px; box-shadow: inset 0 0 25px rgba(0,0,0,0.85); }
        .piano-toolbar, .melody-toolbar { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }
        .piano-action, .melody-action { background: #181818; color: #ddd; border: 1px solid #444; border-radius: 5px; padding: 5px 10px; font-family: inherit; font-weight: bold; font-size: 10px; cursor: pointer; transition: all 0.15s; }
        .piano-action:hover, .melody-action:hover { border-color: var(--neon-primary); color: #fff; }
        .piano-action.active, .melody-action.active { background: var(--neon-primary); color: #000; border-color: var(--neon-primary); box-shadow: 0 0 10px rgba(0,255,204,0.45); }
        .melody-select { background:#111; color:var(--neon-primary); border:1px solid #444; border-radius:5px; padding:5px 8px; font-family:inherit; font-size:10px; font-weight:bold; }
        .melody-mini-control { display:flex; align-items:center; gap:5px; background:#111; border:1px solid #333; border-radius:5px; padding:4px 8px; color:#777; font-size:9px; font-weight:bold; }
        .melody-mini-control input[type=range] { width:72px; accent-color:var(--neon-accent); }
        .piano-hint { color: #555; font-size: 9px; margin-left: auto; letter-spacing: 1px; }
        .octave-readout { color: var(--neon-primary); background: #050505; border: 1px solid #333; border-radius: 4px; padding: 4px 9px; font-size: 10px; font-weight: bold; min-width: 82px; text-align: center; }
        .piano-container { display: flex; justify-content: flex-start; width: 100%; overflow-x: auto; background: #020202; padding: 12px 12px 16px; border-radius: 8px; border: 1px solid #222; box-sizing: border-box; }
        .key { cursor: pointer; box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 4px; padding-bottom: 8px; font-size: 10px; font-weight: bold; transition: all 0.04s; position: relative; flex-shrink: 0; }
        .key.white { width: 46px; height: 156px; background: linear-gradient(180deg, #f3f3f3 0%, #c8c8c8 100%); color: #444; border: 1px solid #999; border-top: none; z-index: 1; border-radius: 0 0 7px 7px; box-shadow: 0 3px 5px rgba(0,0,0,0.5); }
        .key.white:active, .key.white.active, .key.white.latched { background: var(--neon-primary); color: #000; box-shadow: inset 0 0 20px rgba(0,0,0,0.35), 0 0 14px var(--neon-primary); border-color: var(--neon-primary); }
        .key.black { width: 28px; height: 98px; background: linear-gradient(180deg, #222 0%, #000 100%); color: #aaa; border: 1px solid #000; margin-left: -14px; margin-right: -14px; z-index: 2; border-radius: 0 0 5px 5px; box-shadow: inset 0 -3px 4px rgba(255,255,255,0.1), 0 3px 6px rgba(0,0,0,0.85); }
        .key.black:active, .key.black.active, .key.black.latched { background: var(--neon-secondary); color: #fff; box-shadow: 0 0 14px var(--neon-secondary); border-color: var(--neon-secondary); }
        .key-note { font-size: 11px; line-height: 1; }
        .key-map { font-size: 8px; opacity: 0.55; line-height: 1; text-transform: uppercase; }
        .key.black .key-map { color: var(--neon-secondary); }
        .melody-roll { display: grid; grid-template-columns: 52px repeat(16, minmax(28px, 1fr)); gap: 4px; background: #020202; border: 1px solid #222; border-radius: 8px; padding: 8px; overflow-x: auto; }
        .melody-label { color: #666; font-size: 9px; font-weight: bold; text-align: right; padding-right: 6px; align-self: center; }
        .melody-step { min-width: 26px; min-height: 24px; background: #131313; border: 1px solid #2d2d2d; border-radius: 4px; cursor: pointer; transition: all 0.08s; box-sizing: border-box; }
        .melody-step:hover { background: #242424; border-color: #555; }
        .melody-step.active-note { background: var(--neon-accent); border-color: var(--neon-accent); box-shadow: 0 0 11px rgba(170,0,255,0.65); position:relative; }
        .melody-step.poly-note { background: linear-gradient(135deg, var(--neon-accent), var(--neon-primary)); border-color: var(--neon-primary); }
        .melody-step.poly-note::after { content: attr(data-count); position:absolute; right:3px; bottom:1px; font-size:8px; color:#000; font-weight:bold; text-shadow:none; }
        .melody-step.current-col { border: 2px solid #fff; transform: scale(1.08); box-shadow: 0 0 14px rgba(255,255,255,0.75); }
        .melody-step.record-cursor { outline: 2px solid var(--neon-primary); outline-offset: 1px; }
        .melody-step.header { background: transparent; border-color: #222; color: #555; font-size: 8px; display: flex; align-items: center; justify-content: center; cursor: default; }

        .synth-grid { display: grid; grid-template-columns: repeat(8, 1fr); gap: 6px; background: #000; padding: 12px; border-radius: 10px; border: 1px solid #333; }
        .grid-pad { aspect-ratio: 1/1; background-color: #111; border-radius: 6px; border: 1px solid #222; cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 5px; box-sizing: border-box; transition: transform 0.05s; box-shadow: inset 0 -3px 6px rgba(0,0,0,0.5); }
        .grid-pad:hover { background-color: #1a1a1a; }
