    if (seqData.snare[step] && shouldPlay('snare')) playSnare(time + jitter);
    if (seqData.clap[step] && shouldPlay('clap')) playClap(time + jitter);
    if (seqData.rim[step] && shouldPlay('rim')) playRim(time + jitter);
    if (seqData.hat[step] && shouldPlay('hat')) playHiHat(time + jitter);
    if (seqData.openhat[step] && shouldPlay('openhat')) playOpenHat(time + jitter);
    if (seqData.tom[step] && shouldPlay('tom')) playTom(time + jitter);
    if (seqData.perc[step] && shouldPlay('perc')) playPerc(time + jitter);
    if (seqData.ride[step] && shouldPlay('ride')) playRide(time + jitter);
    if (seqData.crash[step] && shouldPlay('crash')) playCrash(time + jitter);
    if (seqData.samp[step] && shouldPlay('samp')) playSample(time + jitter);
