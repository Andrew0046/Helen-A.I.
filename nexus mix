const defaultTrackFx = { filter: 12000, drive: 0, pan: 0, delay: 0, reverb: 0, pitch: 0 };
const trackFX = {};
function cloneDefaultFx(overrides = {}) { return { ...defaultTrackFx, ...overrides }; }
function initDefaultTrackFx() {
