function playSynthNote(freq, element, time = audioCtx.currentTime, isArp = false, velocity = 100) {
    initAudio();
    freq *= getTrackPitchRatio('synth');
    const arpActive = document.getElementById('arpActive').checked;
    
    if (arpActive && !isArp) {
        if (element && !State.arp.notes.includes(element)) State.arp.notes.push(element);
        if (!State.sequencer.isPlaying) document.getElementById('playSeqBtn').click();
        return;
    }

    activeVoices = activeVoices.filter(v => v.osc !== null && !v.isKilled);
    if (activeVoices.length >= MAX_VOICES) { const oldest = activeVoices[0]; if (oldest) stopVoiceProcess(oldest, time, 0.012); }

    if (element) {
        element.classList.add('active'); document.getElementById('currentFreqDisplay').innerText = Math.round(freq);
        element.style.transition = 'all 0.05s';
        element.style.boxShadow = element.classList.contains('key') ? '0 0 25px var(--neon-primary), inset 0 0 15px rgba(0,255,204,0.6)' : '0 0 22px var(--neon-accent), inset 0 0 12px rgba(170,0,255,0.5)';
        setTimeout(() => { if (element) element.style.boxShadow = ''; }, 180);
    }
    
    triggerVisualEvent('synth', 0.7 + (velocity / 200));

    const mode = document.getElementById('synthMode').value;
    const wave = document.getElementById('waveType').value;
    const chordMode = document.getElementById('chordMode').checked;

    const noteGain = audioCtx.createGain();
    const a = State.synth.atk; const d = State.synth.dec; const s = State.synth.sus; const velMod = velocity / 127;
    noteGain.gain.setValueAtTime(0.0001, time);
    
    let voice = { noteGain, element, freq, isKilled: false, oscs: [] };

    const playNote = (f, gainMod = 1) => {
        if (mode === 'lead' || mode === 'hybrid') {
            const osc = audioCtx.createOscillator(); osc.type = wave; osc.frequency.value = f;
            if (mode === 'hybrid') {
                const noise = audioCtx.createBufferSource(); noise.buffer = Engine.noiseBuffer; noise.playbackRate.value = getTrackPitchRatio('synth');
                const noiseFilter = audioCtx.createBiquadFilter(); noiseFilter.type = 'bandpass'; noiseFilter.frequency.value = f * 1.8; noiseFilter.Q.value = 2.5;
                const noiseGain = audioCtx.createGain(); noiseGain.gain.value = 0.035 * velMod * gainMod;
                noise.connect(noiseFilter); noiseFilter.connect(noiseGain); noiseGain.connect(noteGain); noise.start(time); voice.oscs.push(noise);
            }
            noteGain.gain.linearRampToValueAtTime(0.95 * velMod * gainMod, time + a); noteGain.gain.linearRampToValueAtTime(s * velMod * gainMod, time + a + d);
            osc.connect(noteGain); osc.start(time); voice.oscs.push(osc);
        } else if (mode === 'bass') {
            const carrier = audioCtx.createOscillator(); const mod = audioCtx.createOscillator(); const modGain = audioCtx.createGain();
            carrier.type = 'sine'; mod.type = 'sine'; carrier.frequency.value = f * 0.5; mod.frequency.value = f * 1.02; modGain.gain.value = 520 * velMod;
            mod.connect(modGain); modGain.connect(carrier.frequency);
            noteGain.gain.linearRampToValueAtTime(1.0 * velMod * gainMod, time + 0.04); noteGain.gain.linearRampToValueAtTime(0.55 * velMod * gainMod, time + 0.32);
            carrier.connect(noteGain); mod.start(time); carrier.start(time); voice.oscs.push(carrier, mod);
        }
    };

    if (chordMode && !isArp) { playNote(freq, 1.0); playNote(freq * 1.26, 0.72); playNote(freq * 1.5, 0.65); } else { playNote(freq, 1.0); }

    noteGain.connect(Engine.sidechain); activeVoices.push(voice);
    if (isArp) {
        const gateMs = Math.max(50, Math.min(1200, (State.melody && State.melody.gateMs) ? State.melody.gateMs : 110));
        setTimeout(() => { if (voice && !voice.isKilled) stopVoiceProcess(voice, audioCtx.currentTime, 0.06); }, gateMs);
    }
}

function releaseSynthNote(element) {
    if (document.getElementById('arpActive').checked) { State.arp.notes = State.arp.notes.filter(n => n !== element); if (element) element.classList.remove('active'); return; }
    const voice = activeVoices.find(v => v.element === element);
    if (voice) stopVoiceProcess(voice, audioCtx.currentTime, State.synth.rel);
}

function stopVoiceProcess(voice, time, releaseTime) {
    if (!voice || voice.isKilled) return; voice.isKilled = true;
    if (voice.element) voice.element.classList.remove('active');
    voice.noteGain.gain.cancelScheduledValues(time); voice.noteGain.gain.setValueAtTime(voice.noteGain.gain.value, time); voice.noteGain.gain.linearRampToValueAtTime(0.0001, time + releaseTime);
    voice.oscs.forEach(osc => { try { osc.stop(time + releaseTime + 0.05); } catch(e){} });
    setTimeout(() => { if (voice) voice.oscs = []; }, (releaseTime + 0.1) * 1000);
