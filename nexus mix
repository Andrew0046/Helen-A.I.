const MAX_VOICES = 14; let activeVoices = [];

function triggerSidechain(time) {
    const amount = State.synth.sidechain / 100;
    if (amount <= 0.01 || !Engine.sidechain) return;
    Engine.sidechain.gain.cancelScheduledValues(time); Engine.sidechain.gain.setValueAtTime(Engine.sidechain.gain.value, time);
    Engine.sidechain.gain.linearRampToValueAtTime(1 - amount * 0.85, time + 0.018); Engine.sidechain.gain.exponentialRampToValueAtTime(1.0, time + 0.38);
