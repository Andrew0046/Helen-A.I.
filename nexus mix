// Richer synth voices: detuned oscillators, sub support, safer gain staging.
playSynthNote = function(freq, element, time = audioCtx.currentTime, isArp = false, velocity = 100) {
    initAudio();
    freq *= getTrackPitchRatio('synth');
    const arpActive = document.getElementById('arpActive').checked;
    if (arpActive && !isArp) {
        if (element && !State.arp.notes.includes(element)) State.arp.notes.push(element);
        if (!State.sequencer.isPlaying) document.getElementById('playSeqBtn').click();
        return;
    }
    activeVoices = activeVoices.filter(v => v && !v.isKilled);
    if (activeVoices.length >= MAX_VOICES) { const oldest = activeVoices.shift(); if (oldest) stopVoiceProcess(oldest, time, 0.012); }
    if (element) {
        element.classList.add('active'); document.getElementById('currentFreqDisplay').innerText = Math.round(freq);
        element.style.transition = 'all 0.05s';
        element.style.boxShadow = element.classList.contains('key') ? '0 0 25px var(--neon-primary), inset 0 0 15px rgba(0,255,204,0.6)' : '0 0 22px var(--neon-accent), inset 0 0 12px rgba(170,0,255,0.5)';
        setTimeout(() => { if (element) element.style.boxShadow = ''; }, 180);
    }
    triggerVisualEvent('synth', 0.65 + (velocity / 220));
    const mode = document.getElementById('synthMode').value;
    const wave = document.getElementById('waveType').value;
    const chordMode = document.getElementById('chordMode').checked;
    const noteGain = audioCtx.createGain();
    const voiceFilter = audioCtx.createBiquadFilter(); voiceFilter.type = 'lowpass'; voiceFilter.frequency.value = Math.min(16000, Math.max(90, State.synth.filterCutoff * 1.25)); voiceFilter.Q.value = 0.55;
    const a = State.synth.atk, d = State.synth.dec, s = State.synth.sus, velMod = velocity / 127;
    noteGain.gain.setValueAtTime(0.0001, time);
    const voice = { noteGain, element, freq, isKilled: false, oscs: [] };
    const envPeak = Math.min(0.72, 0.42 + velMod * 0.35);
    noteGain.gain.linearRampToValueAtTime(envPeak, time + a);
    noteGain.gain.linearRampToValueAtTime(Math.max(0.0001, envPeak * s), time + a + d);
