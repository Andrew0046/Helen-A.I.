function triggerVisualEvent(type, intensity = 1) {
    if (!canvas || visualMode === 'spectrum') return;
    const centerX = canvas.width * (0.28 + Math.random() * 0.44); const centerY = canvas.height * (0.32 + Math.random() * 0.28);
    if (type === 'kick') spawnParticles(centerX, centerY + 25, 22, '#ff0055', intensity * 1.25, true); 
    else if (type === 'snare') spawnParticles(centerX + 35, centerY - 8, 16, '#00ffcc', intensity * 1.05);
    else if (type === 'hat') spawnParticles(centerX - 25, centerY + 8, 11, '#ffca28', intensity * 0.75);
    else if (type === 'tom') spawnParticles(centerX + 55, centerY + 18, 14, '#aa00ff', intensity);
    else if (type === 'clap') spawnParticles(centerX + 20, centerY - 2, 14, '#ff66cc', intensity);
    else if (type === 'rim') spawnParticles(centerX - 10, centerY + 3, 10, '#66ccff', intensity * 0.8);
    else if (type === 'openhat') spawnParticles(centerX - 35, centerY + 4, 16, '#ffe066', intensity * 0.9);
    else if (type === 'ride') spawnParticles(centerX + 50, centerY - 18, 18, '#b8ff66', intensity);
    else if (type === 'perc') spawnParticles(centerX + 15, centerY + 22, 12, '#ff8844', intensity);
    else if (type === 'crash') spawnParticles(canvas.width * 0.72, centerY - 10, 30, '#ffffff', intensity * 1.4, true);
    else if (type === 'synth') { const col = Math.random() > 0.5 ? '#00ffcc' : '#ff00aa'; spawnParticles(centerX, centerY, 8, col, intensity * 0.85, Math.random() > 0.6); }
