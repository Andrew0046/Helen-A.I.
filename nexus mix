function randomizeDrumPattern() {
    tracks.forEach(track => { if (seqData[track]) seqData[track].fill(false); });
    // Four-on-the-floor skeleton with variation.
    [0, 4, 8, 12].forEach(step => seqData.kick[step] = true);
    [4, 12].forEach(step => seqData.snare[step] = true);
    for (let i = 0; i < 16; i += 2) seqData.hat[i] = true;
    [3, 7, 11, 15].forEach(step => { if (Math.random() < 0.45) seqData.hat[step] = true; });
    [6, 14].forEach(step => { if (Math.random() < 0.6) seqData.clap[step] = true; });
    [2, 10].forEach(step => { if (Math.random() < 0.35) seqData.rim[step] = true; });
