        .voice-card h3 { margin: 0 0 10px; color: var(--neon-primary); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; }
        .voice-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin: 8px 0; }
        .voice-btn { background: #171717; color: #ddd; border: 1px solid #444; border-radius: 6px; padding: 7px 11px; font-family: inherit; font-size: 10px; font-weight: bold; cursor: pointer; transition: transform .08s, border-color .12s, color .12s, box-shadow .12s; }
        .voice-btn:hover { border-color: var(--neon-primary); color: #fff; box-shadow: 0 0 10px rgba(0,255,204,.16); }
        .voice-btn:active { transform: scale(.96); }
        .voice-btn.hot { background: var(--neon-primary); color: #00110d; border-color: var(--neon-primary); }
        .voice-btn.danger { border-color: var(--neon-secondary); color: var(--neon-secondary); }
        .voice-btn.warn { border-color: #ffca28; color: #ffca28; }
        .voice-btn.recording { background: var(--neon-secondary); color: #fff; border-color: var(--neon-secondary); box-shadow: 0 0 16px rgba(255,0,85,.55); animation: pulse 1s infinite; }
        .voice-select, .voice-input { background: #080808; color: var(--neon-primary); border: 1px solid #444; border-radius: 6px; padding: 7px 9px; font-family: inherit; font-size: 11px; outline: none; }
        .voice-input { color: #eee; flex: 1; min-width: 170px; }
        .voice-mini { color: #aaa; font-size: 10px; display: flex; align-items: center; gap: 6px; background:#000; border:1px solid #333; border-radius:6px; padding:6px 8px; }
        .voice-mini input[type="range"] { width: 88px; accent-color: var(--neon-primary); }
        .voice-pads { display: grid; grid-template-columns: repeat(4, minmax(70px, 1fr)); gap: 8px; }
        .voice-pad { min-height: 58px; background: #111; border: 1px solid #333; border-radius: 8px; cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; color: #777; font-size: 10px; font-weight: bold; text-align: center; box-shadow: inset 0 -4px 10px rgba(0,0,0,.45); transition: transform .07s, border-color .1s, color .1s, background .1s; }
        .voice-pad span { font-size: 8px; color: #555; max-width: 92%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .voice-pad.loaded { color: var(--neon-primary); border-color: rgba(0,255,204,.55); background: rgba(0,255,204,.055); }
        .voice-pad.selected { border-color: var(--neon-secondary); box-shadow: 0 0 14px rgba(255,0,85,.28), inset 0 -4px 10px rgba(0,0,0,.45); }
        .voice-pad.active { transform: scale(.96); color:#fff; background: rgba(170,0,255,.18); border-color: var(--neon-accent); }
        .voice-seq-wrap { overflow-x: auto; padding-bottom: 6px; }
        .voice-seq { min-width: 760px; display: grid; grid-template-columns: 54px repeat(16, 1fr); gap: 5px; background: #000; border: 1px solid #282828; border-radius: 9px; padding: 10px; }
        .voice-seq-label { color: #777; font-size: 9px; font-weight: bold; text-align: right; padding-right: 6px; align-self: center; }
        .voice-step { aspect-ratio: 1/1; min-height: 24px; border: 1px solid #333; border-radius: 4px; background: #151515; cursor: pointer; transition: background .08s, border-color .08s, box-shadow .08s; }
        .voice-step:hover { background: #222; }
        .voice-step.on { background: var(--neon-accent); border-color: var(--neon-accent); box-shadow: 0 0 10px rgba(170,0,255,.55); }
        .voice-step.now { outline: 2px solid #fff; outline-offset: -2px; }
        .voice-log { min-height: 74px; max-height: 118px; overflow-y: auto; background: #030303; border: 1px solid #292929; border-radius: 8px; padding: 10px; color: #9be; font-size: 10px; line-height: 1.45; white-space: pre-wrap; }
        .voice-phrase-bank { display:grid; grid-template-columns: repeat(2, minmax(100px, 1fr)); gap: 8px; }
        .voice-phrase { background:#101010; border:1px solid #333; border-radius:7px; padding:8px; color:#bbb; font-size:10px; cursor:pointer; min-height:44px; }
        .voice-phrase:hover { border-color: var(--neon-primary); color:#fff; }


        /* === v4.6 FX LAB + LIVE PERFORMANCE MODE === */
        body.v46-live-mode .studio-container { max-width: 1280px; }
        body.v46-live-mode #tab-fx-live .live-pad { min-height: 86px; font-size: 13px; }
        body.v46-live-mode #tab-fx-live .fx-card { box-shadow: inset 0 0 30px rgba(0,0,0,0.8), 0 0 22px rgba(0,255,204,0.08); }
        .fx-live-grid { display: grid; grid-template-columns: repeat(2, minmax(280px, 1fr)); gap: 14px; }
        .fx-card { background: #070707; border: 1px solid #282828; border-radius: 12px; padding: 14px; box-shadow: inset 0 0 22px rgba(0,0,0,0.75); }
        .fx-card.wide { grid-column: 1 / -1; }
        .fx-card h3 { margin: 0 0 10px; color: var(--neon-primary); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; }
        .fx-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin: 8px 0; }
        .fx-btn, .live-pad { background: #161616; color: #eee; border: 1px solid #444; border-radius: 8px; padding: 9px 12px; font-family: inherit; font-size: 11px; font-weight: bold; cursor: pointer; letter-spacing: 1px; transition: transform .06s, border-color .12s, box-shadow .12s, background .12s; }
        .fx-btn:hover, .live-pad:hover { border-color: var(--neon-primary); box-shadow: 0 0 12px rgba(0,255,204,0.16); }
        .fx-btn:active, .live-pad:active, .live-pad.flash { transform: translateY(1px) scale(0.985); box-shadow: 0 0 20px rgba(0,255,204,0.35); }
        .fx-btn.hot, .live-pad.hot { background: var(--neon-secondary); color: #fff; border-color: var(--neon-secondary); }
        .fx-btn.accent, .live-pad.accent { background: var(--neon-accent); color: #fff; border-color: var(--neon-accent); }
        .fx-btn.warn, .live-pad.warn { background: var(--warning); color: #000; border-color: var(--warning); }
        .fx-btn.active, .live-pad.active { background: var(--neon-primary); color: #000; border-color: var(--neon-primary); box-shadow: 0 0 14px rgba(0,255,204,0.35); }
        .fx-mini { color: #999; font-size: 10px; display: flex; gap: 6px; align-items: center; background: #000; border: 1px solid #252525; padding: 6px 8px; border-radius: 7px; }
        .fx-mini input[type="range"] { width: 105px; accent-color: var(--neon-primary); }
        .fx-select { background: #111; color: var(--neon-primary); border: 1px solid #444; padding: 7px 9px; border-radius: 7px; font-family: inherit; font-weight: bold; font-size: 11px; }
        .fx-seq-wrap { overflow-x: auto; border: 1px solid #222; border-radius: 8px; background: #000; padding: 8px; }
        .fx-seq { display: grid; grid-template-columns: 72px repeat(16, minmax(28px, 1fr)); gap: 5px; min-width: 610px; }
        .fx-seq-label { color: #777; font-size: 9px; font-weight: bold; text-align: right; padding-right: 7px; align-self: center; text-transform: uppercase; }
        .fx-step { aspect-ratio: 1/1; background: #151515; border: 1px solid #333; border-radius: 5px; cursor: pointer; transition: background .1s, border-color .1s, box-shadow .1s; }
        .fx-step:hover { background: #242424; }
        .fx-step.on { background: var(--neon-accent); border-color: var(--neon-accent); box-shadow: 0 0 12px rgba(170,0,255,.45); }
        .fx-step.now { outline: 2px solid #fff; outline-offset: 1px; }
        .live-pad-grid { display: grid; grid-template-columns: repeat(4, minmax(96px, 1fr)); gap: 9px; }
        .live-pad { min-height: 68px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; line-height: 1.2; }
        .live-pad span { display: block; color: rgba(255,255,255,.55); font-size: 9px; margin-top: 4px; letter-spacing: 0; }
        .live-pad.active span { color: rgba(0,0,0,.65); }
        .fx-log { background: #000; border: 1px solid #222; border-radius: 8px; color: #888; min-height: 84px; max-height: 120px; overflow: auto; white-space: pre-wrap; font-size: 10px; padding: 9px; line-height: 1.35; }
        .live-meter-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
        .live-meter { border: 1px solid #222; background: #000; border-radius: 8px; padding: 8px; font-size: 10px; color: #777; }
        .live-meter b { color: var(--neon-primary); float: right; }
        @media (max-width: 760px) {
            .fx-live-grid { grid-template-columns: 1fr; }
            .live-pad-grid { grid-template-columns: repeat(2, minmax(110px, 1fr)); }
        }

    </style>
</head>
<body>

<div class="studio-container">
    
    <!-- TOP BAR -->
    <div class="top-bar">
        <div>
            <span class="branding">NEXUS STUDIO</span>
            <span class="version">PRO v4.7 • STABILITY + LIVE POLISH</span>
        </div>
        
        <div class="status-cluster">
            <div class="midi-status" id="midiStatus">MIDI: OFFLINE</div>
            <div class="readout">FREQ: <span id="currentFreqDisplay">---</span> Hz</div>
            <div class="status-bar" id="statusBar">READY</div>
        </div>
        
        <div class="sys-btns">
            <!-- Presets -->
            <button class="sys-btn" id="savePresetBtn" title="Save current state to slot">💾 SAVE</button>
            <button class="sys-btn" id="loadPresetBtn" title="Load from slot">📂 LOAD</button>
            <select id="presetSlot" style="font-size:10px; padding:4px 6px;">
                <option value="1">Preset 1</option>
                <option value="2">Preset 2</option>
                <option value="3">Preset 3</option>
                <option value="4">Preset 4</option>
            </select>
            
            <button class="sys-btn" id="exportBtn" title="Export session as JSON">EXPORT</button>
            <button class="sys-btn" id="importBtn" title="Import JSON session">IMPORT</button>
            
            <button class="sys-btn record-btn" id="recordBtn">● REC</button>
            <button class="sys-btn panic-btn" id="panicBtn">⚠ PANIC</button>
        </div>
    </div>

    <!-- TABS -->
    <div class="tab-nav">
        <button class="tab-btn active" data-target="tab-synth">SYNTHESIZER</button>
        <button class="tab-btn" data-target="tab-drums">RHYTHM &amp; SEQUENCER</button>
        <button class="tab-btn" data-target="tab-mixer">MASTER MIXER</button>
        <button class="tab-btn" data-target="tab-project">PROJECT TOOLS</button>
        <button class="tab-btn" data-target="tab-smart-composer">SMART COMPOSER</button>
        <button class="tab-btn" data-target="tab-pro-suite">PRO SUITE</button>
        <button class="tab-btn" data-target="tab-voice-lab">VOICE LAB</button>
        <button class="tab-btn" data-target="tab-fx-live">FX LAB / LIVE</button>
    </div>

    <!-- SYNTH TAB -->
    <div id="tab-synth" class="tab-content active">
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">OSCILLATORS • ENVELOPES • ARPEGGIATOR</div>
                
                <div class="control-group">
                    <label style="color:#fff; font-size:10px; display:flex; align-items:center; gap:5px;">
                        <input type="checkbox" id="arpActive"> ARP
                    </label>
                    <select id="arpMode">
                        <option value="up">Up</option>
                        <option value="down">Down</option>
                        <option value="random">Random</option>
                        <option value="updown">Up/Down</option>
                    </select>
                    <select id="synthMode">
                        <option value="lead">Lead / Pad</option>
                        <option value="bass">FM Sub-Bass</option>
                        <option value="hybrid">Hybrid (Saw + Noise)</option>
                    </select>
                    <select id="waveType">
                        <option value="sawtooth">Saw</option>
                        <option value="square">Square</option>
                        <option value="triangle">Triangle</option>
                        <option value="sine">Sine</option>
                    </select>
                    <label style="color:#fff; font-size:10px; display:flex; align-items:center; gap:4px; margin-left:8px;">
                        <input type="checkbox" id="chordMode"> CHORD
                    </label>
                    <label style="color:#fff; font-size:10px; display:flex; align-items:center; gap:4px; margin-left:12px; border-left:1px solid #444; padding-left:10px;">
                        <input type="checkbox" id="keyboardPianoMode"> <span style="color:#00ffcc; font-weight:bold;">⌨ KEYBOARD</span>
                    </label>
                </div>
            </div>
            
            <div class="knob-row">
                <div class="knob-container" id="knob-filterCutoff" data-min="40" data-max="12000" data-val="6500" data-label="Filter"></div>
                <div class="knob-container" id="knob-lfoRate" data-min="0.05" data-max="18" data-val="1.8" data-label="LFO Rate"></div>
                <div class="knob-container" id="knob-lfoDepth" data-min="0" data-max="4200" data-val="180" data-label="LFO Depth"></div>
                <div class="knob-container" id="knob-atk" data-min="0.005" data-max="2.5" data-val="0.08" data-label="Attack"></div>
                <div class="knob-container" id="knob-dec" data-min="0.02" data-max="2.5" data-val="0.28" data-label="Decay"></div>
                <div class="knob-container" id="knob-sus" data-min="0" data-max="1" data-val="0.65" data-label="Sustain"></div>
                <div class="knob-container" id="knob-rel" data-min="0.03" data-max="4.5" data-val="1.1" data-label="Release"></div>
                <div class="knob-container" id="knob-arpRate" data-min="60" data-max="600" data-val="180" data-label="Arp Rate"></div>
                <div class="knob-container" id="knob-swing" data-min="0" data-max="0.6" data-val="0.12" data-label="Swing"></div>
            </div>
        </div>

        <div class="performance-area">
            <div class="piano-module">
                <div class="piano-toolbar">
                    <button class="piano-action" id="octaveDownBtn">OCT −</button>
                    <span class="octave-readout" id="octaveDisplay">C3–C5</span>
                    <button class="piano-action" id="octaveUpBtn">OCT +</button>
                    <label class="piano-action" style="display:flex;align-items:center;gap:5px;">
                        <input type="checkbox" id="pianoLatchMode"> TOGGLE MODE
                    </label>
                    <label class="piano-action" style="display:flex;align-items:center;gap:5px;">
                        <input type="checkbox" id="melodyRecordMode"> STEP REC
                    </label>
                    <button class="piano-action" id="clearHeldBtn">CLEAR HELD</button>
                    <span class="piano-hint">Keyboard map: Z–/ lower octave • Q–Y upper octave • black keys S D G H J / 2 3 5 6 7</span>
                </div>
                <div class="piano-container" id="pianoGrid"></div>
            </div>

            <div class="melody-panel">
                <div class="panel-header" style="margin-bottom:10px; padding-bottom:8px;">
                    <div class="panel-title">SYNTH MELODY SEQUENCER • 16 STEP CHORD PIANO ROLL</div>
                    <div class="melody-toolbar" style="margin-bottom:0;">
                        <select class="melody-select" id="melodyEditMode" title="Mono replaces a step. Chord lets one step hold stacked notes.">
                            <option value="chord">CHORD GRID</option>
                            <option value="mono">MONO GRID</option>
                        </select>
                        <select class="melody-select" id="melodyScale" title="Scale used by Randomize.">
                            <option value="minor">MINOR</option>
                            <option value="major">MAJOR</option>
                            <option value="pentatonic">PENTATONIC</option>
                            <option value="cyber">CYBER</option>
                            <option value="chromatic">CHROMATIC</option>
                        </select>
                        <button class="melody-action" id="prevStepBtn">◀ STEP</button>
                        <button class="melody-action" id="nextStepBtn">STEP ▶</button>
                        <button class="melody-action" id="melodyOctDownBtn">MELODY −12</button>
                        <button class="melody-action" id="melodyOctUpBtn">MELODY +12</button>
                        <button class="melody-action" id="clearStepBtn">CLEAR STEP</button>
                        <button class="melody-action" id="clearMelodyBtn">CLEAR MELODY</button>
                        <button class="melody-action" id="randomMelodyBtn">RANDOMIZE</button>
                        <label class="melody-mini-control">GATE <input type="range" id="melodyGate" min="0.15" max="1.0" step="0.05" value="0.70"><span id="melodyGateDisplay">70%</span></label>
                        <span class="octave-readout" id="recordStepDisplay">REC STEP 1</span>
                    </div>
                </div>
                <div class="roll-edit-toolbar" id="v42RollToolbar">
                    <span class="roll-step-readout" id="v42SelectedStep">STEP 01</span>
                    <label class="melody-mini-control">VEL <input type="range" id="v42StepVelocity" min="25" max="127" step="1" value="112"><span id="v42VelocityDisplay">112</span></label>
                    <label class="melody-mini-control">LEN <input type="range" id="v42StepGate" min="0.15" max="2.00" step="0.05" value="0.70"><span id="v42GateDisplay">70%</span></label>
                    <button class="melody-action" id="v42AuditionStepBtn">AUDITION</button>
                    <button class="melody-action" id="v42NudgeUpBtn">NUDGE +1</button>
                    <button class="melody-action" id="v42NudgeDownBtn">NUDGE −1</button>
                    <button class="melody-action" id="v42CopyStepBtn">COPY STEP</button>
                    <button class="melody-action" id="v42PasteStepBtn">PASTE STEP</button>
                    <button class="melody-action" id="v42DuplicateHalfBtn">DUP 1–8 → 9–16</button>
                    <button class="melody-action" id="v42HumanizeVelBtn">HUMANIZE VEL</button>
                    <span class="piano-roll-tip">Tip: click-drag cells to paint/erase notes. Step length + velocity are saved per step.</span>
                </div>
                <div class="melody-roll" id="melodyGrid"></div>
            </div>

            <div class="synth-grid" id="padGrid"></div>
        </div>
    </div>

    <!-- DRUMS TAB -->
    <div id="tab-drums" class="tab-content">
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">RHYTHM SECTION • SEQUENCER</div>
                
                <div class="control-group">
                    <label style="color:#fff; font-size:11px;">BPM</label>
                    <input type="range" id="bpmSlider" min="55" max="210" value="128" style="width:110px;">
                    <span id="bpmDisplay" style="color:var(--neon-primary); font-weight:bold; font-size:14px; width:32px;">128</span>
                    
                    <button id="playSeqBtn" style="background:var(--neon-primary); border:none; padding:6px 18px; border-radius:6px; font-weight:bold; cursor:pointer; color:#000; font-size:12px;">▶ PLAY</button>
                    
                    <label style="color:#fff; font-size:10px; margin-left:12px;">Humanize</label>
                    <input type="range" id="humanizeSlider" min="0" max="0.8" step="0.05" value="0.15" style="width:80px;">

                    <label style="color:#fff; font-size:10px; margin-left:12px;">Kit</label>
                    <select id="drumKitSelect" title="Change drum machine character">
                        <option value="cyber">Cyber</option>
                        <option value="heavy">Heavy</option>
                        <option value="glitch">Glitch</option>
                        <option value="lofi">Lo-Fi</option>
                    </select>
                </div>
            </div>
            
            <div class="drums-live">
                <div class="drum-pad dp-kick" id="btnKick">KICK<br><span style="font-size:8px;opacity:0.6">(Space)</span></div>
                <div class="drum-pad dp-snare" id="btnSnare">SNARE<br><span style="font-size:8px;opacity:0.6">(Enter)</span></div>
                <div class="drum-pad dp-clap" id="btnClap">CLAP<br><span style="font-size:8px;opacity:0.6">(F)</span></div>
                <div class="drum-pad dp-rim" id="btnRim">RIM<br><span style="font-size:8px;opacity:0.6">(R)</span></div>
                <div class="drum-pad dp-hat" id="btnHat">HAT<br><span style="font-size:8px;opacity:0.6">(Shift)</span></div>
                <div class="drum-pad dp-openhat" id="btnOpenHat">OPEN HAT<br><span style="font-size:8px;opacity:0.6">(O)</span></div>
                <div class="drum-pad dp-tom" id="btnTom">TOM<br><span style="font-size:8px;opacity:0.6">(Bksp)</span></div>
                <div class="drum-pad dp-perc" id="btnPerc">PERC<br><span style="font-size:8px;opacity:0.6">(Y)</span></div>
                <div class="drum-pad dp-ride" id="btnRide">RIDE<br><span style="font-size:8px;opacity:0.6">(U)</span></div>
                <div class="drum-pad dp-crash" id="btnCrash">CRASH<br><span style="font-size:8px;opacity:0.6">(\)</span></div>
                <div class="sampler-drop" id="samplerDrop">DRAG .WAV<br><span style="font-size:8px;">(P)</span></div>
            </div>

            <div class="drum-tools">
                <button class="mini-drum-btn" id="randomBeatBtn">RANDOM BEAT</button>
                <button class="mini-drum-btn" id="addFillBtn">ADD FILL</button>
                <button class="mini-drum-btn danger" id="clearDrumsBtn">CLEAR DRUMS</button>
                <span style="font-size:10px; color:#555;">New rows: CLAP • RIM • OPEN HAT • RIDE • PERC</span>
            </div>
            
            <div class="seq-with-controls">
                <!-- Track Controls (Mute, Solo, Vol, Prob) -->
                <div class="track-controls" id="trackControls"></div>
                <div class="seq-grid" id="seqGrid"></div>
            </div>

            <!-- PATTERN CHAINING / SONG MODE -->
            <div style="margin-top: 16px; border-top: 1px solid #222; padding-top: 14px;">
                <div class="panel-title" style="margin-bottom: 8px;">PATTERNS (A–H) &amp; SONG CHAIN</div>
                
                <div class="pattern-row">
                    <div style="color:#666; font-size:10px; margin-right:6px;">EDIT:</div>
                    <button class="pattern-btn active" data-pattern="A" id="pat-A">A</button>
                    <button class="pattern-btn" data-pattern="B" id="pat-B">B</button>
                    <button class="pattern-btn" data-pattern="C" id="pat-C">C</button>
                    <button class="pattern-btn" data-pattern="D" id="pat-D">D</button>
                    <button class="pattern-btn" data-pattern="E" id="pat-E">E</button>
                    <button class="pattern-btn" data-pattern="F" id="pat-F">F</button>
                    <button class="pattern-btn" data-pattern="G" id="pat-G">G</button>
                    <button class="pattern-btn" data-pattern="H" id="pat-H">H</button>
                    
                    <div style="flex:1"></div>
                    
                    <button class="sys-btn" id="copyPatternBtn" style="font-size:10px; padding:5px 10px;">COPY TO ▸</button>
                    <select id="copyTarget" style="font-size:10px; padding:4px 6px; width:52px;">
                        <option>A</option><option>B</option><option>C</option><option>D</option>
                        <option>E</option><option>F</option><option>G</option><option>H</option>
                    </select>
                </div>

                <div class="song-chain">
                    <div class="song-chain-header">
                        <span>SONG CHAIN</span>
                        <span id="songStatus" style="color:#555; font-size:9px;">IDLE</span>
                    </div>
                    <div class="chain-list" id="chainList"></div>
                    <div class="song-controls">
