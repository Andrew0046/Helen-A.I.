function playSample(time = audioCtx.currentTime) {
    if (!isAudioInit || !Engine.userSampleBuffer) return;
    const source = audioCtx.createBufferSource(); source.buffer = Engine.userSampleBuffer; source.playbackRate.value = (State.mixer.samplePitch || 1.0) * getTrackPitchRatio('samp');
    const trackGain = makeDrumTrackGain('samp'); source.connect(trackGain);
    source.start(time); visTrigger('samplerDrop', time);
}

