        const meta = melodyStepMeta[step] || { velocity: 112, gate: State.melody.gate || .7 };
        State.melody.gateMs = Math.max(45, Math.min(1500, stepDuration * meta.gate * 1000));
        melodyNotes.forEach((midi, noteIndex) => playSynthNote(midiToFreq(midi), null, time + jitter + noteIndex * 0.003, true, Math.max(25, meta.velocity - noteIndex * 5)));
