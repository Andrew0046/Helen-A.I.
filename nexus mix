    }

    function stopTransport() {
        State.sequencer.isPlaying = false;
        transportGeneration++;
        clearTimeout(timerID);
        timerID = null;
        updateTransportButton(false);
        clearStepHighlights();
        safeStatus('SEQUENCER STOPPED');
    }

    toggleSequencer = function() {
        if (State.sequencer.isPlaying) {
            if (isSongMode) stopSongPlayback(false);
            stopTransport();
        } else {
            startTransport();
        }
    };

    playSong = function() {
        if (!Array.isArray(songChain) || songChain.length === 0) { safeStatus('CHAIN IS EMPTY'); return; }
        initAudio();
        clearTimeout(songTimerID);
        songTimerID = null;
        isSongMode = true;
        songIndex = 0;
        stableSong.skipFirstBoundary = true;
        stableSong.barCount = 0;
        assignPatternData(songChain[0], State.sequencer.isPlaying ? 'defer' : 'now');
        updateSongButton(true);
        setSongText(`ARMED ${songChain[0]} • 1/${songChain.length}`);
        updateChainVisual(true);
        if (!State.sequencer.isPlaying) startTransport();
        else {
            State.sequencer.currentStep = 0;
            State.sequencer.nextNoteTime = audioCtx.currentTime + 0.045;
        }
        safeStatus('SONG CHAIN STABLE MODE');
    };

    stopSongPlayback = function(stopTransportFlag = true) {
        isSongMode = false;
        clearTimeout(songTimerID);
        songTimerID = null;
        stableSong.skipFirstBoundary = true;
        updateSongButton(false);
        setSongText(songChain?.length ? `IDLE • ${songChain.length} STEPS` : 'IDLE');
        updateChainVisual(false);
        if (stopTransportFlag && State.sequencer.isPlaying) stopTransport();
    };

    const oldMakeDrumTrackGain441 = makeDrumTrackGain;
    makeDrumTrackGain = function(track, mult = 1) {
        if (!isAudioInit) initAudio();
        const fx = getTrackFx(track);
        const input = audioCtx.createGain();
        const filter = audioCtx.createBiquadFilter();
        const drive = audioCtx.createWaveShaper();
        const pan = audioCtx.createStereoPanner ? audioCtx.createStereoPanner() : audioCtx.createGain();
        const delaySend = audioCtx.createGain();
        const revSend = audioCtx.createGain();

        input.gain.value = Math.max(0, Math.min(1.25, (trackSettings[track]?.vol ?? 1) * mult));
        filter.type = 'lowpass';
        filter.frequency.value = Math.max(80, Math.min(16000, fx.filter || 12000));
        filter.Q.value = 0.72;
        drive.curve = makeTrackDistCurve(Math.max(0, Math.min(42, fx.drive || 0)));
        if (pan.pan) pan.pan.value = Math.max(-1, Math.min(1, fx.pan || 0));
        delaySend.gain.value = Math.max(0, Math.min(0.55, fx.delay || 0));
        revSend.gain.value = Math.max(0, Math.min(0.55, fx.reverb || 0));

        try {
            input.connect(filter); filter.connect(drive); drive.connect(pan); pan.connect(Engine.drumMix);
            if (Engine.delay && delaySend.gain.value > 0.001) { pan.connect(delaySend); delaySend.connect(Engine.delay); }
            if (Engine.rev && revSend.gain.value > 0.001) { pan.connect(revSend); revSend.connect(Engine.rev); }
        } catch(err) {
            try { return oldMakeDrumTrackGain441(track, mult); } catch(e) { return input; }
        }

        const sampleTail = track === 'samp' && Engine.userSampleBuffer ? (Engine.userSampleBuffer.duration * 1000 + 650) : 0;
        const cleanupMs = Math.max(sampleTail, ({ kick: 900, snare: 900, clap: 1000, rim: 700, hat: 420, openhat: 1100, tom: 1000, perc: 800, ride: 1700, crash: 2600 }[track] || 1200));
        setTimeout(() => {
            try { input.disconnect(); } catch(e) {}
            try { filter.disconnect(); } catch(e) {}
            try { drive.disconnect(); } catch(e) {}
            try { pan.disconnect(); } catch(e) {}
            try { delaySend.disconnect(); } catch(e) {}
            try { revSend.disconnect(); } catch(e) {}
        }, cleanupMs);
        return input;
    };

    const oldStopVoiceProcess441 = stopVoiceProcess;
    stopVoiceProcess = function(voice, time, releaseTime) {
        oldStopVoiceProcess441(voice, time, releaseTime);
        const cleanup = Math.max(60, (releaseTime + 0.14) * 1000);
        setTimeout(() => {
            try { voice?.noteGain?.disconnect(); } catch(e) {}
            try { if (voice) voice.oscs = []; } catch(e) {}
        }, cleanup);
    };

    const previousOnload441 = window.onload;
    window.onload = function(...args) {
        if (typeof previousOnload441 === 'function') previousOnload441.apply(this, args);
        try {
            updateTransportButton(!!State.sequencer.isPlaying);
            updateSongButton(!!isSongMode);
            updateChainVisual(false);
            safeStatus('v4.4.1 STABILITY FIX READY');
            if (window.NexusV44?.toast) NexusV44.toast('v4.4.1 stability fix loaded');
        } catch(e) {}
    };
})();


