        for (let i = 0; i < 7; i++) { const x = (canvas.width * 0.1) + (i * 140) + (Math.cos(phase * 0.012 + i) * 15); ctx.beginPath(); ctx.moveTo(x, 15); ctx.lineTo(x, canvas.height - 15); ctx.stroke(); }
