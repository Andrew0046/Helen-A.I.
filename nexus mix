    };
    const addNote = (f, level = 1) => {
        if (mode === 'bass') {
            addOsc(f * .5, 'sine', 0, .72 * level); addOsc(f, 'triangle', -3, .20 * level);
            addOsc(f * .25, 'sine', 0, .18 * level);
        } else {
            addOsc(f, wave, -5, .34 * level); addOsc(f, wave, 5, .34 * level); addOsc(f * .5, 'sine', 0, .12 * level);
            if (mode === 'hybrid') addNoise(f, .035 * level);
        }
    };
    if (chordMode && !isArp) { addNote(freq, 1); addNote(freq * 1.2599, .62); addNote(freq * 1.4983, .55); }
    else addNote(freq, 1);
    voiceFilter.connect(noteGain); noteGain.connect(Engine.sidechain); activeVoices.push(voice);
    if (isArp) { const gateMs = Math.max(45, Math.min(1500, State.melody?.gateMs || 110)); setTimeout(() => { if (voice && !voice.isKilled) stopVoiceProcess(voice, audioCtx.currentTime, 0.055); }, gateMs); }
};

