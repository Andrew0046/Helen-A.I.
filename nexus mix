        Object.assign(trackFX.rim, { drive: 22, delay: 0.25, pan: -0.45, pitch: 7 }); Object.assign(trackFX.perc, { drive: 18, delay: 0.30, pan: 0.42, pitch: 5 });
        Object.assign(trackFX.hat, { filter: 9800, drive: 10, pan: -0.35 }); Object.assign(trackFX.openhat, { delay: 0.18, pan: 0.35 });
