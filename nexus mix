        cleanStream:{ group:'Mix', label:'Clean Stream Master', tag:'safe', color:'mix', knobs:{ drive:4, delayMix:0.10, chorusMix:0.10 }, controls:{ volSynth:.70, volDrum:.80, reverbMix:.24 }, engine:{ hq:true, punch:.58, warmth:.10, air:.38, limiter:.66 }, master:'clean', fx:'cyber', desc:'Clean headroom for exporting ideas.' },
        loudClub:{ group:'Mix', label:'Loud Club Master', tag:'loud', color:'mix', knobs:{ drive:18, delayMix:0.16, chorusMix:0.12 }, controls:{ volSynth:.76, volDrum:.90, reverbMix:.22 }, engine:{ hq:true, punch:.92, warmth:.24, air:.42, limiter:.92 }, master:'loud', fx:'cyber', desc:'Forward drums and louder limiter for drops.' },
        darkCinema:{ group:'Mix', label:'Dark Cinema Master', tag:'wide / dark', color:'mix', knobs:{ drive:10, delayMix:0.24, chorusMix:0.30, filterCutoff:3600 }, controls:{ volSynth:.74, volDrum:.76, reverbMix:.40 }, engine:{ hq:true, punch:.54, warmth:.44, air:.18, limiter:.70 }, master:'dark', fx:'lofi', desc:'Muted cinematic atmosphere with reverb space.' },
        wideFuture:{ group:'Mix', label:'Wide Future Master', tag:'wide / shiny', color:'mix', knobs:{ drive:6, delayMix:0.28, chorusMix:0.48 }, controls:{ volSynth:.78, volDrum:.78, reverbMix:.34 }, engine:{ hq:true, punch:.62, warmth:.12, air:.62, limiter:.76 }, master:'wide', fx:'cyber', desc:'Wide clean synths with bright top end.' },
        radioCrush:{ group:'Mix', label:'Radio Crush', tag:'filtered', color:'mix', knobs:{ drive:34, delayMix:0.18, chorusMix:0.06, filterCutoff:2400 }, controls:{ volSynth:.66, volDrum:.72, reverbMix:.16 }, engine:{ hq:true, punch:.56, warmth:.58, air:.08, limiter:.74 }, master:'dark', fx:'glitch', desc:'Crushed narrow sound for breakdowns/intros.' }
    };

    const STACK_PRESETS = {
        cyberBoss:{ group:'Full Stack', label:'Cyber Boss Stack', tag:'boss battle', color:'stack', synth:'bossLead', drums:'industrialSlam', mix:'loudClub', mood:'boss', desc:'Aggressive lead + hard drums + loud master.' },
        neonTrap:{ group:'Full Stack', label:'Neon Trap Stack', tag:'trap', color:'stack', synth:'distorted808', drums:'trapPunch', mix:'loudClub', mood:'aggressive', desc:'808 bass, punch drums, drop-ready mix.' },
        darkMovie:{ group:'Full Stack', label:'Dark Movie Stack', tag:'cinematic', color:'stack', synth:'ghostPad', drums:'lofiDust', mix:'darkCinema', mood:'dark', desc:'Cinematic pad, dusty drums, dark master.' },
        glitchRunner:{ group:'Full Stack', label:'Glitch Runner Stack', tag:'glitch', color:'stack', synth:'acidPulse', drums:'glitchPerc', mix:'radioCrush', mood:'glitch', desc:'Acid movement, glitch drums, crushed master.' },
        futureKeys:{ group:'Full Stack', label:'Future Keys Stack', tag:'melodic', color:'stack', synth:'glassKeys', drums:'clubClean', mix:'wideFuture', mood:'futuristic', desc:'Clean keys, club kit, wide bright master.' }
    };

    function setControlSafe(id, value) {
        if (typeof setControlValue === 'function') setControlValue(id, value);
        else {
            const el = $(id); if (!el) return;
            if (el.type === 'checkbox') el.checked = !!value; else el.value = value;
            el.dispatchEvent(new Event(el.type === 'range' ? 'input' : 'change', { bubbles:true }));
        }
    }

    function setKnobSafe(id, value) {
        if (typeof setKnobValue === 'function') setKnobValue(id, value);
        else if (State?.synth) { State.synth[id] = value; if (typeof updateAudioParam === 'function') updateAudioParam(id, value); }
    }

    function syncEngineControls() {
        const defs = [ ['v42Punch','punch','v42PunchDisplay'], ['v42Warmth','warmth','v42WarmthDisplay'], ['v42Air','air','v42AirDisplay'], ['v42Limiter','limiter','v42LimiterDisplay'] ];
        defs.forEach(([id,key,display]) => {
            const val = Number(State?.engine?.[key] ?? 0);
            const input = $(id); const out = $(display);
            if (input) input.value = val;
            if (out) out.textContent = `${Math.round(val * 100)}%`;
        });
        const hq = $('v42HQEngine'); if (hq) hq.checked = State?.engine?.hq !== false;
        try { if (typeof updateV42SoundEngine === 'function') updateV42SoundEngine(); } catch(e) {}
    }

    function applyEngine(engine) {
        if (!engine) return;
        State.engine = Object.assign({ hq:true, punch:.70, warmth:.18, air:.35, limiter:.78 }, State.engine || {}, engine);
        syncEngineControls();
    }

    function applyFxMap(map) {
        if (!map || typeof trackFX !== 'object') return;
        Object.entries(map).forEach(([track, values]) => {
            if (!trackFX[track]) trackFX[track] = typeof cloneDefaultFx === 'function' ? cloneDefaultFx() : {};
            Object.assign(trackFX[track], values);
        });
        try { if (typeof updateSynthTrackFx === 'function') updateSynthTrackFx(); } catch(e) {}
        try { if (typeof buildTrackFxMatrix === 'function') buildTrackFxMatrix(); } catch(e) {}
    }

    function applyVolumes(volumes) {
        if (!volumes || typeof trackSettings !== 'object') return;
        Object.entries(volumes).forEach(([track, vol]) => {
            if (trackSettings[track]) trackSettings[track].vol = Number(vol);
        });
        try { if (typeof initTrackControls === 'function') initTrackControls(); } catch(e) {}
    }

    function applyBasicControls(controls = {}) {
        Object.entries(controls).forEach(([id, value]) => setControlSafe(id, value));
    }

    function applyKnobs(knobs = {}) {
        Object.entries(knobs).forEach(([id, value]) => setKnobSafe(id, value));
    }

    function updatePresetReadout(kind, preset) {
        const readout = $('v48PresetReadout');
        if (readout) readout.innerHTML = `<b>${preset.label}</b><span>${preset.desc || ''}</span>`;
        const last = $('v48LastPreset');
        if (last) last.textContent = `${kind.toUpperCase()}: ${preset.label}`;
    }

    function applySynthPreset(name, shouldAudition = false) {
        const preset = SYNTH_PRESETS[name]; if (!preset) return;
        try { if (typeof initAudio === 'function') initAudio(); } catch(e) {}
        applyBasicControls(preset.controls);
        applyKnobs(preset.knobs);
        applyEngine(preset.engine);
        applyFxMap(preset.fx);
        V48.lastPreset = `synth:${name}`;
        V48.auditionNote = preset.note || 60;
        updatePresetReadout('synth', preset);
        try { if (typeof autoSave === 'function') autoSave(); } catch(e) {}
        try { if (typeof updateStatus === 'function') updateStatus(`SYNTH PRESET: ${preset.label.toUpperCase()}`); } catch(e) {}
        if (shouldAudition) auditionPresetNote(preset.note || 60);
    }

    function applyDrumPreset(name, shouldAudition = false) {
        const preset = DRUM_PRESETS[name]; if (!preset) return;
        try { if (typeof initAudio === 'function') initAudio(); } catch(e) {}
        if (preset.kit) setControlSafe('drumKitSelect', preset.kit);
        if (preset.bpm) setControlSafe('bpmSlider', preset.bpm);
        applyEngine(preset.engine);
        applyVolumes(preset.volumes);
        applyFxMap(preset.fx);
        V48.lastPreset = `drums:${name}`;
        updatePresetReadout('drums', preset);
        try { if (typeof autoSave === 'function') autoSave(); } catch(e) {}
        try { if (typeof updateStatus === 'function') updateStatus(`DRUM PRESET: ${preset.label.toUpperCase()}`); } catch(e) {}
        if (shouldAudition) auditionDrums();
    }

    function applyMixPreset(name) {
        const preset = MIX_PRESETS[name]; if (!preset) return;
        try { if (typeof initAudio === 'function') initAudio(); } catch(e) {}
        if (preset.fx && typeof applyFxPreset === 'function') applyFxPreset(preset.fx);
        if (preset.master && typeof applyMasterPreset === 'function') applyMasterPreset(preset.master);
        applyBasicControls(preset.controls);
        applyKnobs(preset.knobs);
        applyEngine(preset.engine);
        V48.lastPreset = `mix:${name}`;
        updatePresetReadout('mix', preset);
        try { if (typeof autoSave === 'function') autoSave(); } catch(e) {}
        try { if (typeof updateStatus === 'function') updateStatus(`MIX PRESET: ${preset.label.toUpperCase()}`); } catch(e) {}
    }

    function applyStackPreset(name, shouldAudition = false) {
        const preset = STACK_PRESETS[name]; if (!preset) return;
        applySynthPreset(preset.synth, false);
        applyDrumPreset(preset.drums, false);
        applyMixPreset(preset.mix);
        if (preset.mood) {
            const mood = $('v43MoodSelect'); if (mood) setControlSafe('v43MoodSelect', preset.mood);
        }
        V48.lastPreset = `stack:${name}`;
        updatePresetReadout('stack', preset);
        try { if (typeof updateStatus === 'function') updateStatus(`FULL SOUND STACK: ${preset.label.toUpperCase()}`); } catch(e) {}
        if (shouldAudition) { auditionPresetNote(V48.auditionNote || 60); setTimeout(auditionDrums, 90); }
    }

    function auditionPresetNote(midi = 60) {
        try {
            if (typeof initAudio === 'function') initAudio();
            const freq = 440 * Math.pow(2, (midi - 69) / 12);
            if (typeof playSynthNote === 'function') {
                playSynthNote(freq, null, audioCtx.currentTime, false, 108);
                const voice = activeVoices?.[activeVoices.length - 1];
                if (voice && typeof stopVoiceProcess === 'function') setTimeout(() => stopVoiceProcess(voice, audioCtx.currentTime, State.synth.rel || .6), 420);
            }
        } catch(err) { console.warn('v4.8 audition note warning', err); }
    }

    function auditionDrums() {
        try {
            if (typeof initAudio === 'function') initAudio();
            const t = audioCtx.currentTime + 0.02;
            if (typeof playKick === 'function') playKick(t);
            if (typeof playHiHat === 'function') playHiHat(t + 0.13);
            if (typeof playSnare === 'function') playSnare(t + 0.26);
            if (typeof playClap === 'function') playClap(t + 0.265);
            if (typeof playOpenHat === 'function') playOpenHat(t + 0.39);
        } catch(err) { console.warn('v4.8 drum audition warning', err); }
    }

    function installStyles() {
