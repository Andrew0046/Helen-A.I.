// Sequencer Data
const seqGrid = document.getElementById('seqGrid');
let seqData = {
    kick: Array(16).fill(false), snare: Array(16).fill(false), clap: Array(16).fill(false), rim: Array(16).fill(false),
    hat: Array(16).fill(false), openhat: Array(16).fill(false), tom: Array(16).fill(false), perc: Array(16).fill(false),
    ride: Array(16).fill(false), crash: Array(16).fill(false), samp: Array(16).fill(false)
};
let melodyData = Array.from({ length: 16 }, () => []);
const tracks = ['kick', 'snare', 'clap', 'rim', 'hat', 'openhat', 'tom', 'perc', 'ride', 'crash', 'samp'];
let timerID = null; let uiDrawQueue = [];

function renderSeqGrid() {
    seqGrid.innerHTML = '';
    tracks.forEach(track => {
        const label = document.createElement('div'); label.className = 'seq-label'; label.innerText = track.toUpperCase(); seqGrid.appendChild(label);
        for (let i = 0; i < 16; i++) {
