            this.midiInput.addEventListener('change', async () => { const f=this.midiInput.files?.[0]; if (!f) return; try { const arr=await f.arrayBuffer(); this.importMidiToMelody(new Uint8Array(arr)); } catch(e){ console.error(e); updateStatus('MIDI IMPORT FAILED'); } this.midiInput.value=''; });
            document.body.appendChild(this.midiInput);
