function playSong() {
    if (songChain.length === 0) { updateStatus('CHAIN IS EMPTY'); return; }
    initAudio(); isSongMode = true; songIndex = 0;
    const btn = document.getElementById('playSongBtn'); btn.innerText = '■ STOP SONG'; btn.style.background = 'var(--neon-secondary)'; document.getElementById('songStatus').innerText = `PLAYING ${songChain[0]}`;
