function makeEmptySeq() { const o = {}; tracks.forEach(t => o[t] = Array(16).fill(false)); return o; }
function makeMelodyFromScale(base, scale, density = 0.62, chordEvery = 4) {
    return Array.from({ length: 16 }, (_, step) => {
        if (Math.random() > density) return [];
        const root = base + scale[(step * 2 + Math.floor(Math.random() * 2)) % scale.length];
        if (step % chordEvery === 0) return [root, root + 7, root + 12].filter(n => n <= 96);
        if (Math.random() < 0.23) return [root, root + 7].filter(n => n <= 96);
        return [root];
    });
}
function makeGenrePattern(genre = 'cyber', variant = 0) {
    const d = makeEmptySeq();
    const scale = melodyScales[genre === 'house' ? 'minor' : genre === 'lofi' ? 'pentatonic' : genre === 'trap' ? 'minor' : 'cyber'] || melodyScales.cyber;
    let bpm = 128, kit = 'cyber', density = 0.58;
    if (genre === 'trap') { bpm = 142; kit = 'heavy'; density = 0.45; }
    if (genre === 'house') { bpm = 126; kit = 'cyber'; density = 0.55; }
    if (genre === 'lofi') { bpm = 84; kit = 'lofi'; density = 0.48; }
    if (genre === 'dnb') { bpm = 174; kit = 'glitch'; density = 0.64; }
    if (genre === 'industrial') { bpm = 118; kit = 'heavy'; density = 0.52; }

    const four = [0,4,8,12]; const backbeat = genre === 'trap' || genre === 'dnb' ? [4,12] : [4,12];
    if (genre === 'house') four.forEach(s => d.kick[s] = true);
    else if (genre === 'dnb') [0,3,8,10].forEach(s => d.kick[s] = true);
    else if (genre === 'trap') [0,7,10,14].forEach(s => d.kick[s] = true);
    else if (genre === 'industrial') [0,2,6,8,10,14].forEach(s => d.kick[s] = true);
    else [0,4,8,11,14].forEach(s => d.kick[s] = true);
    backbeat.forEach(s => d.snare[s] = true);
    if (variant > 1) d.clap[12] = true;
    for (let i = 0; i < 16; i += (genre === 'trap' ? 1 : 2)) d.hat[i] = true;
    if (genre === 'dnb') [2,6,10,14].forEach(s => d.openhat[s] = true);
    if (genre === 'house') [3,7,11,15].forEach(s => d.openhat[s] = true);
    if (genre === 'industrial') [1,5,9,13].forEach(s => d.rim[s] = true);
    if (variant >= 1) [5,13].forEach(s => d.perc[s] = true);
    if (variant >= 2) [15,14,13].forEach((s,i) => { d.tom[s] = i % 2 === 0; d.perc[s] = true; });
    if (variant === 0) d.crash[0] = true;
    const melody = makeMelodyFromScale(genre === 'lofi' ? 48 : 60, scale, density, variant >= 2 ? 4 : 8);
    return { drums: d, melody, bpm, kit };
}
function buildFullSong(genre = 'cyber') {
    const letters = ['A','B','C','D'];
