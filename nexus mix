                chainCard.classList.toggle('danger', chain.tone === 'danger');
            }
            const start = document.getElementById('v44StartText');
            if (start) start.textContent = currentPattern ? `Editing pattern ${currentPattern}. Use Smart Composer for ideas.` : 'Generate chords, groove, bassline, then arrange.';
            const sound = document.getElementById('v44SoundText');
            if (sound) {
