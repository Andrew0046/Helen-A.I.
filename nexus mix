initDefaultTrackFx();

const fxTrackOrder = ['synth', 'kick', 'snare', 'clap', 'rim', 'hat', 'openhat', 'tom', 'perc', 'ride', 'crash', 'samp'];
const fxTrackLabels = { synth: 'SYNTH', kick: 'KICK', snare: 'SNARE', clap: 'CLAP', rim: 'RIM', hat: 'HAT', openhat: 'OPEN', tom: 'TOM', perc: 'PERC', ride: 'RIDE', crash: 'CRASH', samp: 'SAMPLE' };

function makeTrackDistCurve(amount = 0) {
    const n = 2048; const curve = new Float32Array(n);
    if (amount <= 0.1) { for (let i = 0; i < n; i++) curve[i] = (i * 2 / n) - 1; return curve; }
    const k = amount * 1.35;
    for (let i = 0; i < n; i++) {
        const x = i * 2 / n - 1;
        curve[i] = (1 + k) * x / (1 + k * Math.abs(x));
    }
    return curve;
}

function getTrackFx(track) { return trackFX[track] || defaultTrackFx; }
function getTrackPitchRatio(track) { return Math.pow(2, (getTrackFx(track).pitch || 0) / 12); }
function formatFxValue(key, value) {
    if (key === 'filter') return value >= 1000 ? (value / 1000).toFixed(1) + 'k' : Math.round(value) + 'Hz';
    if (key === 'pan') return value < -0.02 ? 'L ' + Math.abs(value).toFixed(2) : value > 0.02 ? 'R ' + value.toFixed(2) : 'C';
    if (key === 'pitch') return (value > 0 ? '+' : '') + Math.round(value) + 'st';
    return Math.round(value * 100) + '%';
}
function updateSynthTrackFx() {
    if (!isAudioInit || !Engine.synthFxFilter) return;
    const fx = getTrackFx('synth');
    Engine.synthFxFilter.frequency.setTargetAtTime(Math.max(80, fx.filter), audioCtx.currentTime, 0.015);
    Engine.synthFxDrive.curve = makeTrackDistCurve(fx.drive);
    if (Engine.synthFxPan.pan) Engine.synthFxPan.pan.setTargetAtTime(fx.pan, audioCtx.currentTime, 0.015);
    Engine.synthFxDelaySend.gain.setTargetAtTime(fx.delay, audioCtx.currentTime, 0.015);
    Engine.synthFxRevSend.gain.setTargetAtTime(fx.reverb, audioCtx.currentTime, 0.015);
}
function resetTrackFx(track) {
    trackFX[track] = cloneDefaultFx(track === 'synth' ? { delay: 0.12, reverb: 0.18 } : {});
    if (track === 'synth') updateSynthTrackFx();
    buildTrackFxMatrix();
    updateStatus(`${fxTrackLabels[track] || track} FX RESET`);
    autoSave();
}
