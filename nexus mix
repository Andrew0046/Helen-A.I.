    Object.keys(trackFX).forEach(k => trackFX[k] = cloneDefaultFx());
    trackFX.synth.delay = 0.12; trackFX.synth.reverb = 0.18;
    updateSynthTrackFx(); buildTrackFxMatrix(); updateStatus('ALL TRACK FX RESET'); autoSave();
}
function applyFxPreset(type) {
    resetAllTrackFx();
    if (type === 'cyber') {
        Object.assign(trackFX.synth, { pan: -0.12, delay: 0.24, reverb: 0.20 });
        Object.assign(trackFX.clap, { pan: 0.22, reverb: 0.22 }); Object.assign(trackFX.hat, { pan: -0.28 }); Object.assign(trackFX.ride, { pan: 0.34, reverb: 0.18 });
        Object.assign(trackFX.perc, { pan: -0.18, delay: 0.18 });
    } else if (type === 'lofi') {
        fxTrackOrder.forEach(t => Object.assign(trackFX[t], { filter: t === 'kick' ? 3200 : 5200, drive: t === 'synth' ? 7 : 4, reverb: 0.06 }));
        Object.assign(trackFX.synth, { filter: 4400, pitch: -12, reverb: 0.22 }); Object.assign(trackFX.samp, { filter: 3600, pitch: -5 });
    } else if (type === 'glitch') {
