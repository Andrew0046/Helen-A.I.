function stopSongPlayback() {
    isSongMode = false; clearTimeout(songTimerID); document.getElementById('playSongBtn').innerText = '▶ PLAY SONG'; document.getElementById('playSongBtn').style.background = 'var(--neon-accent)'; document.getElementById('songStatus').innerText = 'IDLE';
    if (State.sequencer.isPlaying) document.getElementById('playSeqBtn').click();
