    function mutatePatch(){
        const p = ensureState();
        const jitter = (amt) => (Math.random() * amt * 2 - amt);
        ['oscMix','subLevel','noiseLevel','stereo','filterEnv','filterDrive','synthChorus','synthPhaser','synthFlanger','bitcrush','widener','macroBrightness','macroAggression','macroSpace','macroMovement','vibratoDepth'].forEach(k => p[k] = clamp((Number(p[k])||0) + jitter(.14), 0, 1));
        p.osc2Semi = clamp((Number(p.osc2Semi)||0) + [-12,-7,-5,0,5,7,12][Math.floor(Math.random()*7)], -24, 24);
        p.osc2Detune = clamp((Number(p.osc2Detune)||0) + Math.round(jitter(9)), -50, 50);
        p.unison = clamp(Math.round((Number(p.unison)||3) + jitter(1.2)), 1, 7);
        p.unisonDetune = clamp((Number(p.unisonDetune)||8) + Math.round(jitter(6)), 0, 35);
        p.lastPatch = 'Mutated ' + (p.lastPatch || 'Patch');
