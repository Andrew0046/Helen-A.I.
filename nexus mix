        sections.forEach(sec => {
            const pat = Patterns[sec.pattern] || capturePatternSnapshot(); const drums = pat.drums || seqData; const melody = normalizeMelodyData(pat.melody || melodyData);
            for (let bar=0; bar<(sec.bars||1); bar++) {
