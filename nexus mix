function buildTrackFxMatrix() {
    const container = document.getElementById('trackFxMatrix'); if (!container) return;
    container.innerHTML = '';
    const head = document.createElement('div'); head.className = 'fx-row fx-head';
    ['Track', 'Filter', 'Drive', 'Pan', 'Delay', 'Reverb', 'Pitch', 'Reset'].forEach(text => { const cell = document.createElement('div'); cell.innerText = text; head.appendChild(cell); });
    container.appendChild(head);
    const specs = {
        filter: { min: 500, max: 12000, step: 100, cls: '' }, drive: { min: 0, max: 60, step: 1, cls: 'drive' }, pan: { min: -1, max: 1, step: 0.05, cls: '' },
        delay: { min: 0, max: 0.75, step: 0.05, cls: 'send' }, reverb: { min: 0, max: 0.75, step: 0.05, cls: 'send' }, pitch: { min: -24, max: 24, step: 1, cls: '' }
    };
    fxTrackOrder.forEach(track => {
        if (!trackFX[track]) trackFX[track] = cloneDefaultFx();
        const row = document.createElement('div'); row.className = 'fx-row';
        const label = document.createElement('div'); label.className = 'fx-track-name'; label.innerText = fxTrackLabels[track] || track.toUpperCase(); row.appendChild(label);
        ['filter', 'drive', 'pan', 'delay', 'reverb', 'pitch'].forEach(key => {
            const spec = specs[key]; const cell = document.createElement('div'); cell.className = `fx-cell ${spec.cls}`;
            const range = document.createElement('input'); range.type = 'range'; range.min = spec.min; range.max = spec.max; range.step = spec.step; range.value = trackFX[track][key];
            const value = document.createElement('span'); value.className = 'fx-value'; value.innerText = formatFxValue(key, parseFloat(range.value));
            range.addEventListener('input', () => {
                trackFX[track][key] = parseFloat(range.value); value.innerText = formatFxValue(key, trackFX[track][key]);
                if (track === 'synth') updateSynthTrackFx();
                autoSave();
            });
            cell.appendChild(range); cell.appendChild(value); row.appendChild(cell);
        });
        const reset = document.createElement('button'); reset.className = 'fx-reset'; reset.innerText = 'RST'; reset.addEventListener('click', () => resetTrackFx(track)); row.appendChild(reset);
        container.appendChild(row);
    });
}

let soloActive = false;
let currentDrumKit = 'cyber';
const DrumKits = {
    cyber: { kickStart: 142, kickEnd: 38, kickDecay: 0.65, snareFreq: 1650, hatFreq: 5200, noiseTone: 1.0 },
    heavy: { kickStart: 172, kickEnd: 32, kickDecay: 0.82, snareFreq: 1250, hatFreq: 4600, noiseTone: 0.85 },
    glitch: { kickStart: 118, kickEnd: 44, kickDecay: 0.42, snareFreq: 2200, hatFreq: 7200, noiseTone: 1.25 },
    lofi: { kickStart: 96, kickEnd: 36, kickDecay: 0.58, snareFreq: 980, hatFreq: 3900, noiseTone: 0.65 }
};
function getKit() { return DrumKits[currentDrumKit] || DrumKits.cyber; }
function makeDrumTrackGain(track, mult = 1) {
    const fx = getTrackFx(track);
    const input = audioCtx.createGain();
    const filter = audioCtx.createBiquadFilter();
    const drive = audioCtx.createWaveShaper();
    const pan = audioCtx.createStereoPanner ? audioCtx.createStereoPanner() : audioCtx.createGain();
    const delaySend = audioCtx.createGain();
    const revSend = audioCtx.createGain();

    input.gain.value = (trackSettings[track]?.vol ?? 1) * mult;
    filter.type = 'lowpass'; filter.frequency.value = Math.max(80, fx.filter || 12000); filter.Q.value = 0.8;
    drive.curve = makeTrackDistCurve(fx.drive || 0);
    if (pan.pan) pan.pan.value = fx.pan || 0;
    delaySend.gain.value = fx.delay || 0;
    revSend.gain.value = fx.reverb || 0;

    input.connect(filter); filter.connect(drive); drive.connect(pan); pan.connect(Engine.drumMix);
    if (Engine.delay) { pan.connect(delaySend); delaySend.connect(Engine.delay); }
    if (Engine.rev) { pan.connect(revSend); revSend.connect(Engine.rev); }

    setTimeout(() => { try { input.disconnect(); filter.disconnect(); drive.disconnect(); pan.disconnect(); delaySend.disconnect(); revSend.disconnect(); } catch(e){} }, 12000);
    return input;
}

function playKick(time = audioCtx.currentTime) {
