            .v48-title { font-size:14px; letter-spacing:3px; color:#fff; font-weight:bold; text-transform:uppercase; }
            .v48-sub { font-size:11px; color:#aaa; line-height:1.45; max-width:760px; }
            .v48-readout { background:#000; border:1px solid #333; border-radius:10px; padding:10px 12px; min-width:220px; color:#aaa; font-size:10px; }
            .v48-readout b { display:block; color:var(--neon-primary); font-size:12px; margin-bottom:4px; letter-spacing:1px; }
            .v48-section { background:rgba(0,0,0,.42); border:1px solid #222; border-radius:14px; padding:14px; }
            .v48-section-head { display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:10px; border-bottom:1px solid #222; padding-bottom:9px; }
            .v48-section-title { color:#ddd; font-size:11px; text-transform:uppercase; letter-spacing:2px; }
            .v48-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(170px, 1fr)); gap:10px; }
            .v48-card { background:#101010; border:1px solid #303030; border-radius:12px; padding:12px; cursor:pointer; transition:transform .12s, border-color .12s, box-shadow .12s, background .12s; min-height:94px; display:flex; flex-direction:column; gap:7px; }
            .v48-card:hover { transform:translateY(-1px); border-color:var(--neon-primary); box-shadow:0 0 16px rgba(0,255,204,.12); background:#121818; }
            .v48-card[data-color="bass"] { border-left:3px solid #ff0055; }
            .v48-card[data-color="lead"] { border-left:3px solid #00ffcc; }
            .v48-card[data-color="keys"], .v48-card[data-color="pad"] { border-left:3px solid #aa00ff; }
            .v48-card[data-color="drum"] { border-left:3px solid #ffca28; }
            .v48-card[data-color="mix"] { border-left:3px solid #66aaff; }
            .v48-card[data-color="stack"] { border-left:3px solid #fff; }
            .v48-name { color:#fff; font-size:12px; font-weight:bold; letter-spacing:1px; text-transform:uppercase; display:flex; justify-content:space-between; gap:8px; }
            .v48-tag { color:#111; background:var(--neon-primary); border-radius:999px; padding:2px 7px; font-size:8px; white-space:nowrap; height:max-content; }
            .v48-card[data-color="bass"] .v48-tag { background:#ff0055; color:#fff; }
            .v48-card[data-color="drum"] .v48-tag { background:#ffca28; color:#000; }
            .v48-card[data-color="mix"] .v48-tag { background:#66aaff; color:#000; }
            .v48-card[data-color="stack"] .v48-tag { background:#fff; color:#000; }
            .v48-desc { color:#888; font-size:10px; line-height:1.35; }
            .v48-actions { display:flex; gap:8px; flex-wrap:wrap; }
            .v48-btn { background:#1b1b1b; border:1px solid #444; color:#ddd; border-radius:8px; padding:8px 11px; font-family:inherit; font-size:10px; font-weight:bold; cursor:pointer; text-transform:uppercase; letter-spacing:1px; }
            .v48-btn:hover { border-color:var(--neon-primary); color:#fff; }
            .v48-btn.hot { background:var(--neon-primary); color:#00110e; border-color:var(--neon-primary); }
            .v48-btn.warn { background:#ffca28; color:#000; border-color:#ffca28; }
            .v48-btn.danger { background:#2a1218; color:#ff8cac; border-color:#663344; }
            .v48-mini { font-size:9px; color:#666; }
            .v48-tools { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
            .v48-select { background:#050505; color:var(--neon-primary); border:1px solid #444; border-radius:7px; padding:7px 10px; font-family:inherit; font-size:10px; }
            body.v48-preset-focus .studio-container { box-shadow:0 0 135px rgba(0,255,204,.18), inset 0 0 18px rgba(0,255,204,.04); }
            @media (max-width: 740px) { .v48-grid { grid-template-columns:1fr; } .v48-hero { align-items:stretch; } .v48-readout { width:100%; } }
        `;
        document.head.appendChild(style);
    }

    function cardHtml(kind, key, preset) {
        return `<div class="v48-card" data-v48-kind="${kind}" data-v48-preset="${key}" data-color="${preset.color || 'mix'}" title="Click to apply. Shift-click or use Audition to preview.">
            <div class="v48-name"><span>${preset.label}</span><span class="v48-tag">${preset.tag || preset.group}</span></div>
            <div class="v48-desc">${preset.desc || ''}</div>
            <div class="v48-mini">${preset.group || kind}</div>
        </div>`;
    }

    function createSoundPresetTab() {
        if ($('tab-sound-presets')) return;
        const nav = document.querySelector('.tab-nav');
        const btn = document.createElement('button');
        btn.className = 'tab-btn';
        btn.dataset.target = 'tab-sound-presets';
        btn.textContent = 'SOUND PRESETS';
        nav?.appendChild(btn);

        const tab = document.createElement('div');
        tab.id = 'tab-sound-presets';
        tab.className = 'tab-content';
        tab.innerHTML = `
            <div class="panel v48-wrap">
                <div class="v48-hero">
                    <div>
                        <div class="v48-title">v4.8 Finished Sound Presets</div>
                        <div class="v48-sub">One-click sound design for bass, leads, pads, drums, and master tone. These presets adjust synth mode, envelopes, track FX, drum balance, HQ engine, and mixer color together.</div>
                    </div>
                    <div class="v48-readout" id="v48PresetReadout"><b>READY</b><span>Pick a preset, then audition or generate a matching idea.</span></div>
                </div>

                <div class="v48-section">
                    <div class="v48-section-head">
                        <div class="v48-section-title">Quick Actions</div>
                        <div class="v48-tools">
                            <select class="v48-select" id="v48AuditionNote"><option value="43">Low G Bass</option><option value="48">C2 Bass</option><option value="60">C3 Middle</option><option value="67">G Lead</option><option value="72">C4 High</option></select>
                            <button class="v48-btn hot" id="v48AuditionBtn">AUDITION SYNTH</button>
                            <button class="v48-btn" id="v48AuditionDrumsBtn">AUDITION DRUMS</button>
                            <button class="v48-btn warn" id="v48MakeIdeaBtn">MAKE IDEA WITH SOUND</button>
                            <button class="v48-btn danger" id="v48ResetSoundBtn">RESET FX</button>
                        </div>
                    </div>
                    <div class="v48-mini">Last preset: <span id="v48LastPreset">none</span></div>
                </div>

                <div class="v48-section">
                    <div class="v48-section-head"><div class="v48-section-title">Synth / Bass / Pad Presets</div><div class="v48-mini">finished instruments</div></div>
                    <div class="v48-grid">${Object.entries(SYNTH_PRESETS).map(([k,p]) => cardHtml('synth', k, p)).join('')}</div>
                </div>

                <div class="v48-section">
                    <div class="v48-section-head"><div class="v48-section-title">Drum Sound Presets</div><div class="v48-mini">kit + track FX + balance</div></div>
                    <div class="v48-grid">${Object.entries(DRUM_PRESETS).map(([k,p]) => cardHtml('drums', k, p)).join('')}</div>
                </div>

                <div class="v48-section">
                    <div class="v48-section-head"><div class="v48-section-title">Mix / Master Color</div><div class="v48-mini">master chain + sends</div></div>
                    <div class="v48-grid">${Object.entries(MIX_PRESETS).map(([k,p]) => cardHtml('mix', k, p)).join('')}</div>
                </div>

                <div class="v48-section">
                    <div class="v48-section-head"><div class="v48-section-title">Full Sound Stacks</div><div class="v48-mini">instrument + drums + master</div></div>
                    <div class="v48-grid">${Object.entries(STACK_PRESETS).map(([k,p]) => cardHtml('stack', k, p)).join('')}</div>
                </div>
            </div>`;
        const visualizerWrap = document.querySelector('#visualizer')?.parentElement;
        if (visualizerWrap) visualizerWrap.parentElement.insertBefore(tab, visualizerWrap);
        else document.querySelector('.studio-container')?.appendChild(tab);

        btn.addEventListener('click', () => showTab('tab-sound-presets'));
        tab.querySelectorAll('[data-v48-preset]').forEach(card => {
            card.addEventListener('click', (e) => {
                const kind = card.dataset.v48Kind;
                const name = card.dataset.v48Preset;
                const audition = e.shiftKey;
                if (kind === 'synth') applySynthPreset(name, audition);
                if (kind === 'drums') applyDrumPreset(name, audition);
                if (kind === 'mix') applyMixPreset(name);
                if (kind === 'stack') applyStackPreset(name, audition);
            });
        });
    }

    function showTab(id) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        $(id)?.classList.add('active');
        document.querySelector(`.tab-btn[data-target="${id}"]`)?.classList.add('active');
    }

    function makeIdeaWithSound() {
        const last = V48.lastPreset || '';
        let genre = 'cyber';
        if (last.includes('trap') || last.includes('808')) genre = 'trap';
        if (last.includes('lofi') || last.includes('darkMovie')) genre = 'lofi';
        if (last.includes('glitch')) genre = 'industrial';
        if (last.includes('futureKeys') || last.includes('club')) genre = 'house';
        try {
            if (typeof buildFullSong === 'function') buildFullSong(genre);
            else if (window.ProSuite?.generateFullIdea) window.ProSuite.generateFullIdea(genre);
            if (typeof updateStatus === 'function') updateStatus(`v4.8 IDEA GENERATED WITH ${genre.toUpperCase()} SOUND`);
        } catch(err) {
            console.warn('v4.8 idea warning', err);
            try { if (typeof updateStatus === 'function') updateStatus('v4.8 IDEA WARNING'); } catch(e) {}
        }
    }

    function wireUI() {
        $('v48AuditionBtn')?.addEventListener('click', () => auditionPresetNote(parseInt($('v48AuditionNote')?.value || V48.auditionNote || 60, 10)));
        $('v48AuditionDrumsBtn')?.addEventListener('click', auditionDrums);
        $('v48MakeIdeaBtn')?.addEventListener('click', makeIdeaWithSound);
        $('v48ResetSoundBtn')?.addEventListener('click', () => {
            try { if (typeof resetAllTrackFx === 'function') resetAllTrackFx(); } catch(e) {}
            applyEngine({ hq:true, punch:.70, warmth:.18, air:.35, limiter:.78 });
            applyKnobs({ drive:12, delayMix:.22, chorusMix:.18, sidechain:72 });
            applyBasicControls({ volSynth:.75, volDrum:.82, reverbMix:.35 });
            updatePresetReadout('reset', { label:'Sound Reset', desc:'Track FX and engine returned to a safe balanced tone.' });
        });
    }

    function installProjectHooks() {
        if (window.__nexusV48ProjectHooksInstalled) return;
        window.__nexusV48ProjectHooksInstalled = true;
        if (typeof captureProjectSnapshot === 'function') {
            const oldCapture = captureProjectSnapshot;
            captureProjectSnapshot = function(){
                const snap = oldCapture();
                snap.v48 = { lastPreset: V48.lastPreset, auditionNote: V48.auditionNote };
                return snap;
            };
        }
        if (typeof applyProjectSnapshot === 'function') {
            const oldApply = applyProjectSnapshot;
            applyProjectSnapshot = function(snap){
                oldApply(snap);
                if (snap?.v48) {
                    V48.lastPreset = snap.v48.lastPreset || 'none';
                    V48.auditionNote = Number(snap.v48.auditionNote || 60);
                    const last = $('v48LastPreset'); if (last) last.textContent = V48.lastPreset;
                }
            };
        }
    }

    function boot() {
        try {
            installStyles();
            createSoundPresetTab();
            wireUI();
            installProjectHooks();
            document.body.classList.add('v48-preset-focus');
            const brandVersion = document.querySelector('.version');
            if (brandVersion) brandVersion.textContent = 'PRO v4.8 • FINISHED SOUND PRESETS';
            try { if (typeof updateStatus === 'function') updateStatus('v4.8 SOUND PRESETS READY'); } catch(e) {}
            V48.installed = true;
        } catch(err) {
            console.error('v4.8 boot warning', err);
            try { if (typeof updateStatus === 'function') updateStatus('v4.8 BOOT WARNING'); } catch(e) {}
        }
    }

    const previousOnload48 = window.onload;
    window.onload = function(...args){
        if (typeof previousOnload48 === 'function') previousOnload48.apply(this, args);
        boot();
    };
})();


</script>
