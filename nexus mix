function watchSongChain() {
    if (!isSongMode) return;
    songTimerID = setTimeout(() => {
        if (!isSongMode || !State.sequencer.isPlaying) return;
        if (State.sequencer.currentStep === 0 && songIndex < songChain.length - 1) {
            songIndex++; const nextPattern = songChain[songIndex]; document.getElementById('songStatus').innerText = `PLAYING ${nextPattern}`; loadPattern(nextPattern);
        } else if (State.sequencer.currentStep === 0 && songIndex >= songChain.length - 1) {
            if (document.getElementById('songLoop').checked) { songIndex = 0; const first = songChain[0]; document.getElementById('songStatus').innerText = `LOOPING ${first}`; loadPattern(first); } 
            else { stopSongPlayback(); updateStatus('SONG FINISHED'); return; }
        }
        if (isSongMode) watchSongChain();
    }, 80);
}

